---
/*
 * BaseLayout.astro — Layout base del sito
 * Contiene <head> con meta, fonts, analytics placeholder.
 * Per modificare SEO/meta: aggiorna le props o i valori di default qui sotto.
 */

interface Props {
  title?: string;
  description?: string;
  canonical?: string;
  lang?: 'it' | 'en';
}

const {
  title = 'Agent Engineering Studio — Laboratorio & community su agenti AI',
  description = 'Laboratorio aperto di sperimentazione, formazione e divulgazione su agenti AI: proof-of-concept, progetti open-source e materiale didattico.',
  canonical = 'https://agentengineering.it/',
  lang = 'it',
} = Astro.props;

const ogImage = new URL('/logo-horizontal.png', canonical).href;
---

<!DOCTYPE html>
<html lang={lang}>
<head>
  <meta charset="utf-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1" />
  <title>{title}</title>
  <meta name="description" content={description} />
  <link rel="canonical" href={canonical} />
  <meta name="theme-color" content="#0a0e17" />

  <!-- Favicon -->
  <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
  <link rel="apple-touch-icon" href="/logo-icon.png" />

  <!-- Open Graph -->
  <meta property="og:type" content="website" />
  <meta property="og:title" content={title} />
  <meta property="og:description" content={description} />
  <meta property="og:url" content={canonical} />
  <meta property="og:image" content={ogImage} />
  <meta property="og:site_name" content="Agent Engineering Studio" />

  <!-- Twitter Card -->
  <meta name="twitter:card" content="summary_large_image" />
  <meta name="twitter:title" content={title} />
  <meta name="twitter:description" content={description} />
  <meta name="twitter:image" content={ogImage} />

  <!-- Google Fonts: JetBrains Mono + Outfit -->
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link
    href="https://fonts.googleapis.com/css2?family=JetBrains+Mono:wght@400;700&family=Outfit:wght@300;400;500;600;700&display=swap"
    rel="stylesheet"
  />

  <!-- Global CSS -->
  <style is:global>
    @import '../styles/global.css';
  </style>

  <!-- TODO: analytics -->
</head>
<body>
  <slot />

  <!-- Easter egg console message -->
  <script is:inline>
    console.log('%c🔬 Agent Engineering Studio', 'font-size:16px;font-weight:bold;color:#2196F3');
    console.log('%cVuoi contribuire? → github.com/agent-engineering-studio', 'font-size:12px;color:#e0e6ed');
  </script>
</body>
</html>
