---
/*
 * index.astro — Landing page Agent Engineering Studio
 * Pagina principale single-page. Assembla tutti i componenti.
 * Per modificare l'ordine delle sezioni: riordina i componenti nel <main>.
 */

import BaseLayout from '../layouts/BaseLayout.astro';
import Hero from '../components/Hero.astro';
import Pillars from '../components/Pillars.astro';
import SocialLinks from '../components/SocialLinks.astro';
import BookSection from '../components/BookSection.astro';
import ProjectsSection from '../components/ProjectsSection.astro';
import Footer from '../components/Footer.astro';
---

<BaseLayout>
  <main>
    <Hero />
    <Pillars />
    <BookSection />
    <ProjectsSection />
    <SocialLinks />
  </main>
  <Footer />
</BaseLayout>
