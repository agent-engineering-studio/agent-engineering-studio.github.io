---
/*
 * knowledge-graph.astro — Pagina dedicata al libro
 * "AI che Ragiona"
 *
 * Edizione: Italiano
 * Formati: Paperback, Hardcover, eBook Kindle
 * Cover: Neo4j-style Knowledge Graph diagram (v7)
 */

import BaseLayout from '../../layouts/BaseLayout.astro';
import Footer from '../../components/Footer.astro';

const AMAZON_IT_URL = 'https://www.amazon.it/gp/product/B0GWRX64Z8/ref=ox_sc_act_title_1?smid=A1FPE5JXJST57&psc=1';
const GITHUB_DISCUSSIONS_URL = 'https://github.com/orgs/agent-engineering-studio/discussions';

const parts = [
  { number: 'I', title: 'Fondamenti dei Knowledge Graph', chapters: '1-4', desc: 'Teoria KG, modelli dati (RDF, Property Graph), query Cypher/SPARQL, ontologie OWL e ragionamento' },
  { number: 'II', title: 'Costruire con Python', chapters: '5-12', desc: 'Quick Start in 30 min, architettura, pipeline ingestion, Docker Compose, Pydantic, Vector Store' },
  { number: 'III-V', title: 'RAG, KGC e Pipeline', chapters: '13-20', desc: 'Graph-RAG vs RAG classico, ricerca ibrida, KG Completion, pipeline da testo, metriche qualità' },
  { number: 'VI', title: 'Model Context Protocol', chapters: '21-24', desc: 'Architettura MCP, server per KG, tool custom, sicurezza enterprise, debug' },
  { number: 'VII+', title: 'Agent AI e Business', chapters: '25-32', desc: '7 agenti orchestrati con MAF, confronto framework, pricing, ROI, deployment cloud enterprise' },
];

const stack = ['Python 3.11+', 'Neo4j', 'Redis Stack', 'Ollama (qwen2.5:14b + nomic-embed-text)', 'FastMCP', 'Microsoft Agent Framework', 'FastAPI', 'Next.js', 'Docker Compose'];

const highlights = [
  { icon: '📖', label: '500+ pagine full color' },
  { icon: '💻', label: 'Codice Python eseguibile' },
  { icon: '🏗️', label: 'Architetture enterprise reali' },
  { icon: '🤖', label: '7 agenti orchestrati con MAF' },
  { icon: '🔗', label: 'MCP + Knowledge Graph' },
  { icon: '📊', label: 'Caso enterprise 18 mesi, ROI reale' },
];

const formats = [
  { icon: '📖', title: 'Paperback', details: ['7" × 10" — Full color', 'Carta bianca premium, copertina lucida'] },
  { icon: '📕', title: 'Hardcover', details: ['7" × 10" — Full color', 'Copertina rigida, dorso stampato'] },
  { icon: '📱', title: 'eBook Kindle', details: ['EPUB 3.0 — Reflowable', 'TOC navigabile, 35 figure'] },
];
---

<BaseLayout
  title="AI che Ragiona — Agent Engineering Studio"
  description="Oltre 500 pagine di codice Python eseguibile per costruire Knowledge Graph enterprise, pipeline Graph-RAG ibride, server MCP e crew di agenti orchestrati con Microsoft Agent Framework. Dalla teoria al deployment, senza scorciatoie."
>
  <main>
    <!-- Hero -->
    <section class="book-hero">
      <div class="container">
        <a href="/" class="back-link">&larr; Agent Engineering Studio</a>

        <div class="book-hero__layout">
          <div class="book-hero__info">
            <span class="badge-new">Edizione 2026</span>
            <h1 class="book-hero__title">
              AI che Ragiona<br/>
              <span class="accent">Da sviluppatore a Solution Architect</span>
            </h1>
            <p class="book-hero__subtitle">
              Knowledge Graph, Graph-RAG e Agenti Multi-Modello in Produzione
              con Python, Neo4j, MCP e Microsoft Agent Framework.
            </p>
            <p class="book-hero__author">
              di <strong>Giuseppe Zileni</strong> — AI Senior Software Architect @ Hevolus Innovation
            </p>

            <!-- Amazon CTA -->
            <div class="book-hero__actions">
              <a href={AMAZON_IT_URL} target="_blank" rel="noopener noreferrer" class="btn-amazon">
                Acquista su Amazon
              </a>
            </div>
            <div class="book-hero__badge-row">
              <a
                href={AMAZON_IT_URL}
                target="_blank"
                rel="noopener noreferrer"
                aria-label="Available at Amazon"
              >
                <img
                  src="/badges/available_at_amazon_en_horizontal_drk.png"
                  alt="Available at Amazon"
                  class="amazon-badge-img"
                  width="180"
                  height="46"
                  loading="eager"
                />
              </a>
            </div>
            <p class="trademark">
              Amazon's trademark is used under license from Amazon.com, Inc. or its affiliates.
            </p>
          </div>

          <!-- Book cover — real image -->
          <div class="book-hero__cover">
            <div class="cover-3d">
              <img
                src="/covers/ai-che-ragiona-it-ebook-cover.jpg"
                alt="Copertina: AI che Ragiona"
                class="cover-3d__img"
                width="320"
                height="512"
                loading="eager"
              />
            </div>
          </div>
        </div>
      </div>
    </section>

    <!-- Highlights -->
    <section class="highlights">
      <div class="container">
        <div class="highlights__grid">
          {highlights.map((h) => (
            <div class="highlight-item">
              <span class="highlight-item__icon" aria-hidden="true">{h.icon}</span>
              <span class="highlight-item__label">{h.label}</span>
            </div>
          ))}
        </div>
      </div>
    </section>

    <!-- Description -->
    <section class="description">
      <div class="container">
        <h2 class="section-title">Di cosa parla il libro</h2>
        <div class="description__content">
          <p class="lead">
            <em>Le chatbot rispondono. I sistemi che ragionano decidono.</em>
          </p>
          <p>
            La maggior parte dei libri sull'AI si ferma al notebook Jupyter. <strong>Questo no.</strong>
            Ogni riga di codice è stata scritta, eseguita e messa in produzione — puoi farlo anche tu,
            sulla tua macchina, stasera. Fai <code>git clone</code> del repository e nel giro di un caffè
            avrai il tuo primo Knowledge Graph in esecuzione.
          </p>
          <p>
            <strong>AI che Ragiona</strong> colma il divario fra teoria accademica e sistema enterprise
            che paga le bollette. Oltre <strong>500 pagine</strong> di codice Python eseguibile,
            architetture di produzione, calcoli di ROI difendibili davanti a un CFO e uno
            <strong>studio di caso end-to-end da 18 mesi</strong>.
          </p>
          <p>
            Dai <strong>Knowledge Graph</strong> — la stessa tecnologia dietro al grafo Google da 1,6
            trilioni di triple — alle due evoluzioni che nel 2025-2026 ridefiniscono come l'AI viene
            progettata e venduta: il <strong>Model Context Protocol</strong> di Anthropic e
            l'<strong>orchestrazione multi-agente</strong> con Microsoft Agent Framework.
            Tutto eseguibile con un singolo <code>docker compose up</code>.
          </p>
          <p>
            Pensato per <strong>developer Python, AI/ML engineer e architect</strong> che cercano codice
            completo e pattern di produzione, ma anche per <strong>CTO, PM, consulenti AI e founder</strong>
            che vogliono casi d'uso per settore, ROI difendibili, modello di pricing e go-to-market.
          </p>
        </div>
      </div>
    </section>

    <!-- Table of contents -->
    <section class="toc">
      <div class="container">
        <h2 class="section-title">Struttura del libro</h2>
        <div class="toc__grid">
          {parts.map((part) => (
            <div class="toc-card">
              <div class="toc-card__header">
                <span class="toc-card__number">Parte {part.number}</span>
                <span class="toc-card__chapters">Cap. {part.chapters}</span>
              </div>
              <h3 class="toc-card__title">{part.title}</h3>
              <p class="toc-card__desc">{part.desc}</p>
            </div>
          ))}
        </div>
      </div>
    </section>

    <!-- Stack -->
    <section class="tech-stack">
      <div class="container">
        <h2 class="section-title">Stack Tecnologico</h2>
        <div class="stack-tags">
          {stack.map((tech) => (
            <span class="stack-tag">{tech}</span>
          ))}
        </div>
      </div>
    </section>

    <!-- Formats -->
    <section class="formats">
      <div class="container">
        <h2 class="section-title">Formati disponibili</h2>
        <div class="formats__grid">
          {formats.map((fmt) => (
            <div class="format-card">
              <span class="format-card__icon" aria-hidden="true">{fmt.icon}</span>
              <h3 class="format-card__title">{fmt.title}</h3>
              {fmt.details.map((d) => (
                <p class="format-card__detail">{d}</p>
              ))}
            </div>
          ))}
        </div>

        <!-- Final Amazon CTA -->
        <div class="formats__cta">
          <a href={AMAZON_IT_URL} target="_blank" rel="noopener noreferrer" class="btn-amazon btn-amazon--lg">
            Acquista su Amazon
          </a>
          <a
            href={AMAZON_IT_URL}
            target="_blank"
            rel="noopener noreferrer"
            aria-label="Available at Amazon"
          >
            <img
              src="/badges/available_at_amazon_en_horizontal_drk.png"
              alt="Available at Amazon"
              class="amazon-badge-img"
              width="180"
              height="46"
              loading="lazy"
            />
          </a>
          <p class="trademark">
            Amazon's trademark is used under license from Amazon.com, Inc. or its affiliates.
          </p>
        </div>
      </div>
    </section>

    <!-- Community / Discussions -->
    <section class="community">
      <div class="container">
        <a
          href={GITHUB_DISCUSSIONS_URL}
          target="_blank"
          rel="noopener noreferrer"
          class="community__card"
        >
          <div class="community__icon" aria-hidden="true">
            <svg viewBox="0 0 24 24" width="40" height="40" fill="currentColor">
              <path d="M12 .297c-6.63 0-12 5.373-12 12 0 5.303 3.438 9.8 8.205 11.385.6.113.82-.258.82-.577 0-.285-.01-1.04-.015-2.04-3.338.724-4.042-1.61-4.042-1.61C4.422 18.07 3.633 17.7 3.633 17.7c-1.087-.744.084-.729.084-.729 1.205.084 1.838 1.236 1.838 1.236 1.07 1.835 2.809 1.305 3.495.998.108-.776.417-1.305.76-1.605-2.665-.3-5.466-1.332-5.466-5.93 0-1.31.465-2.38 1.235-3.22-.135-.303-.54-1.523.105-3.176 0 0 1.005-.322 3.3 1.23.96-.267 1.98-.4 3-.405 1.02.005 2.04.138 3 .405 2.28-1.552 3.285-1.23 3.285-1.23.645 1.653.24 2.873.12 3.176.765.84 1.23 1.91 1.23 3.22 0 4.61-2.805 5.625-5.475 5.92.42.36.81 1.096.81 2.22 0 1.606-.015 2.896-.015 3.286 0 .315.21.69.825.57C20.565 22.092 24 17.592 24 12.297c0-6.627-5.373-12-12-12"/>
            </svg>
          </div>
          <div class="community__body">
            <span class="community__eyebrow">Community</span>
            <h3 class="community__title">Unisciti alla discussione</h3>
            <p class="community__desc">
              Domande sul codice, idee, segnalazioni, casi d'uso reali: la conversazione
              continua sulle GitHub Discussions di Agent Engineering Studio.
            </p>
          </div>
          <div class="community__arrow" aria-hidden="true">→</div>
        </a>
      </div>
    </section>
  </main>
  <Footer />
</BaseLayout>

<style>
  /* ── Back link ── */
  .back-link {
    display: inline-block;
    font-family: var(--font-heading);
    font-size: 0.8rem;
    color: var(--color-text-muted);
    margin-bottom: var(--space-xl);
    transition: color var(--transition-fast);
  }
  .back-link:hover { color: var(--color-accent); }

  /* ── Hero ── */
  .book-hero {
    padding: var(--space-3xl) 0 var(--space-2xl);
  }

  .book-hero__layout {
    display: flex;
    gap: var(--space-3xl);
    align-items: flex-start;
  }

  .book-hero__info {
    flex: 1;
  }

  .badge-new {
    display: inline-block;
    padding: 0.2em 0.8em;
    font-family: var(--font-heading);
    font-size: 0.7rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    color: var(--color-bg);
    background: var(--color-accent);
    border-radius: 999px;
    margin-bottom: var(--space-lg);
  }

  .book-hero__title {
    font-family: var(--font-heading);
    font-size: clamp(1.8rem, 5vw, 2.8rem);
    font-weight: 700;
    line-height: 1.15;
    color: var(--color-text);
    margin-bottom: var(--space-md);
  }

  .accent { color: var(--color-accent); }

  .book-hero__subtitle {
    font-size: clamp(0.95rem, 2vw, 1.15rem);
    color: var(--color-text-muted);
    line-height: 1.6;
    max-width: 560px;
    margin-bottom: var(--space-md);
  }

  .book-hero__author {
    font-size: 0.9rem;
    color: var(--color-text-muted);
    margin-bottom: var(--space-lg);
  }

  .book-hero__author strong {
    color: var(--color-text);
  }

  /* ── Amazon CTA ── */
  .book-hero__actions {
    display: flex;
    align-items: center;
    gap: var(--space-md);
    flex-wrap: wrap;
    margin-bottom: var(--space-md);
  }

  .book-hero__badge-row {
    margin-bottom: var(--space-sm);
  }

  .btn-amazon {
    display: inline-flex;
    align-items: center;
    gap: var(--space-sm);
    padding: 0.7em 1.6em;
    background: #ff9900;
    color: #0a0e17;
    font-family: var(--font-heading);
    font-size: 0.85rem;
    font-weight: 700;
    border-radius: var(--border-radius);
    text-decoration: none;
    transition: background var(--transition-fast), transform var(--transition-fast), box-shadow var(--transition-fast);
  }

  .btn-amazon:hover {
    background: #ffad33;
    color: #0a0e17;
    transform: translateY(-2px);
    box-shadow: 0 4px 24px rgba(255, 153, 0, 0.35);
  }

  .btn-amazon--secondary {
    background: transparent;
    color: #ff9900;
    border: 1px solid #ff9900;
  }

  .btn-amazon--secondary:hover {
    background: rgba(255, 153, 0, 0.1);
    color: #ffad33;
    border-color: #ffad33;
  }

  .btn-amazon--sm {
    font-size: 0.78rem;
    padding: 0.5em 1.2em;
  }

  .btn-amazon--lg {
    font-size: 1rem;
    padding: 0.8em 2em;
  }

  .amazon-badge-img {
    height: 40px;
    width: auto;
    display: block;
  }

  .trademark {
    font-size: 0.6rem;
    color: var(--color-text-muted);
    opacity: 0.4;
  }

  /* ── Cover 3D ── */
  .book-hero__cover {
    flex-shrink: 0;
  }

  .cover-3d {
    width: 260px;
    perspective: 900px;
  }

  .cover-3d__img {
    width: 100%;
    height: auto;
    border-radius: 4px 12px 12px 4px;
    box-shadow:
      -4px 0 0 rgba(33, 150, 243, 0.15),
      -6px 1px 0 rgba(33, 150, 243, 0.08),
      0 8px 40px rgba(0, 0, 0, 0.5),
      0 0 60px rgba(33, 150, 243, 0.08);
    transform: rotateY(-6deg);
    transition: transform var(--transition-base), box-shadow var(--transition-base);
  }

  .cover-3d:hover .cover-3d__img {
    transform: rotateY(-2deg) translateY(-4px);
    box-shadow:
      -3px 0 0 rgba(33, 150, 243, 0.2),
      -5px 1px 0 rgba(33, 150, 243, 0.12),
      0 12px 48px rgba(0, 0, 0, 0.6),
      0 0 80px rgba(33, 150, 243, 0.12);
  }

  /* ── Highlights ── */
  .highlights {
    padding: var(--space-xl) 0;
    border-top: 1px solid var(--color-border);
    border-bottom: 1px solid var(--color-border);
  }

  .highlights__grid {
    display: flex;
    flex-wrap: wrap;
    justify-content: center;
    gap: var(--space-md);
  }

  .highlight-item {
    display: flex;
    align-items: center;
    gap: var(--space-sm);
    padding: var(--space-sm) var(--space-md);
    background: var(--color-bg-card);
    border: 1px solid var(--color-border);
    border-radius: 999px;
    font-family: var(--font-heading);
    font-size: 0.8rem;
    color: var(--color-text-muted);
  }

  .highlight-item__icon { font-size: 1.1rem; }

  /* ── Section titles ── */
  .section-title {
    font-family: var(--font-heading);
    font-size: 0.85rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    color: var(--color-accent);
    text-align: center;
    margin-bottom: var(--space-xl);
  }

  /* ── Description ── */
  .description {
    padding: var(--space-3xl) 0;
  }

  .description__content {
    max-width: 680px;
    margin: 0 auto;
  }

  .description__content p {
    font-size: 0.95rem;
    color: var(--color-text-muted);
    line-height: 1.7;
    text-align: center;
    margin-bottom: var(--space-md);
  }

  .description__content p.lead {
    font-size: 1.15rem;
    color: var(--color-text);
    line-height: 1.5;
    margin-bottom: var(--space-lg);
  }

  .description__content p.lead em {
    background: linear-gradient(90deg, var(--color-accent), #9c5bff);
    -webkit-background-clip: text;
    background-clip: text;
    -webkit-text-fill-color: transparent;
    font-style: italic;
  }

  .description__content strong {
    color: var(--color-text);
  }

  .description__content em {
    color: var(--color-text);
    font-style: italic;
  }

  .description__content code {
    font-family: var(--font-mono, ui-monospace, SFMono-Regular, Menlo, monospace);
    font-size: 0.85em;
    padding: 0.1em 0.4em;
    background: var(--color-bg-card);
    border: 1px solid var(--color-border);
    border-radius: 4px;
    color: var(--color-accent);
  }

  /* ── TOC ── */
  .toc {
    padding: var(--space-2xl) 0 var(--space-3xl);
    border-top: 1px solid var(--color-border);
  }

  .toc__grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: var(--space-md);
    max-width: 720px;
    margin: 0 auto;
  }

  .toc-card {
    background: var(--color-bg-card);
    border: 1px solid var(--color-border);
    border-radius: var(--border-radius-lg);
    padding: var(--space-lg);
    transition: border-color var(--transition-base), box-shadow var(--transition-base);
  }

  .toc-card:hover {
    border-color: rgba(33,150,243,0.3);
    box-shadow: 0 0 16px var(--color-accent-glow);
  }

  .toc-card__header {
    display: flex;
    justify-content: space-between;
    align-items: baseline;
    margin-bottom: var(--space-xs);
  }

  .toc-card__number {
    font-family: var(--font-heading);
    font-size: 0.7rem;
    font-weight: 700;
    color: var(--color-accent);
    text-transform: uppercase;
    letter-spacing: 0.05em;
  }

  .toc-card__chapters {
    font-family: var(--font-heading);
    font-size: 0.75rem;
    color: var(--color-text-muted);
  }

  .toc-card__title {
    font-family: var(--font-heading);
    font-size: 1.05rem;
    font-weight: 600;
    color: var(--color-text);
    margin-bottom: var(--space-xs);
  }

  .toc-card__desc {
    font-size: 0.85rem;
    color: var(--color-text-muted);
    line-height: 1.5;
  }

  /* ── Stack ── */
  .tech-stack {
    padding: var(--space-2xl) 0;
    border-top: 1px solid var(--color-border);
  }

  .stack-tags {
    display: flex;
    flex-wrap: wrap;
    justify-content: center;
    gap: var(--space-sm);
  }

  .stack-tag {
    padding: 0.3em 0.9em;
    font-family: var(--font-heading);
    font-size: 0.8rem;
    color: var(--color-text-muted);
    background: var(--color-bg-card);
    border: 1px solid var(--color-border);
    border-radius: 999px;
    transition: border-color var(--transition-base);
  }

  .stack-tag:hover {
    border-color: rgba(33,150,243,0.3);
    color: var(--color-accent);
  }

  /* ── Formats ── */
  .formats {
    padding: var(--space-2xl) 0 var(--space-3xl);
    border-top: 1px solid var(--color-border);
  }

  .formats__grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: var(--space-lg);
    max-width: 720px;
    margin: 0 auto var(--space-2xl);
  }

  .format-card {
    background: var(--color-bg-card);
    border: 1px solid var(--color-border);
    border-radius: var(--border-radius-lg);
    padding: var(--space-lg);
    text-align: center;
  }

  .format-card__icon { font-size: 2rem; display: block; margin-bottom: var(--space-sm); }
  .format-card__title { font-family: var(--font-heading); font-size: 1rem; font-weight: 700; color: var(--color-text); margin-bottom: var(--space-xs); }
  .format-card__detail { font-size: 0.8rem; color: var(--color-text-muted); line-height: 1.5; }

  .formats__cta {
    text-align: center;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: var(--space-md);
  }

  /* ── Community / Discussions ── */
  .community {
    padding: var(--space-2xl) 0 var(--space-3xl);
    border-top: 1px solid var(--color-border);
  }

  .community__card {
    display: flex;
    align-items: center;
    gap: var(--space-lg);
    max-width: 720px;
    margin: 0 auto;
    padding: var(--space-lg) var(--space-xl);
    background:
      radial-gradient(circle at top left, rgba(33, 150, 243, 0.12), transparent 60%),
      radial-gradient(circle at bottom right, rgba(156, 91, 255, 0.12), transparent 60%),
      var(--color-bg-card);
    border: 1px solid var(--color-border);
    border-radius: var(--border-radius-lg);
    text-decoration: none;
    color: inherit;
    transition:
      border-color var(--transition-base),
      box-shadow var(--transition-base),
      transform var(--transition-base);
  }

  .community__card:hover {
    border-color: rgba(33, 150, 243, 0.4);
    box-shadow: 0 0 28px var(--color-accent-glow);
    transform: translateY(-2px);
  }

  .community__icon {
    flex-shrink: 0;
    display: grid;
    place-items: center;
    width: 64px;
    height: 64px;
    border-radius: 50%;
    color: var(--color-text);
    background: linear-gradient(135deg, rgba(33, 150, 243, 0.18), rgba(156, 91, 255, 0.18));
    border: 1px solid rgba(33, 150, 243, 0.35);
    transition: transform var(--transition-base);
  }

  .community__card:hover .community__icon {
