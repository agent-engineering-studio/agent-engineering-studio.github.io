---
/*
 * knowledge-graph.astro — Pagina dedicata al libro
 * "AI che Ragiona"
 *
 * Edizioni: Italiano + English
 * Formati: Paperback, Hardcover, eBook Kindle
 * Cover: Neo4j-style Knowledge Graph diagram (v7)
 *
 * TODO: Aggiornare AMAZON_IT_URL e AMAZON_EN_URL con gli URL reali Amazon.
 */

import BaseLayout from '../../layouts/BaseLayout.astro';
import Footer from '../../components/Footer.astro';

const AMAZON_IT_URL = '#'; // TODO: inserire URL Amazon IT
const AMAZON_EN_URL = '#'; // TODO: inserire URL Amazon EN

const editions = [
  {
    lang: 'it',
    flag: '🇮🇹',
    label: 'Edizione Italiana',
    title: 'AI che Ragiona',
    subtitle: 'Un percorso completo dalla teoria accademica all\'implementazione enterprise con Python, Neo4j e Microsoft Agent Framework.',
    cover: '/covers/ai-che-ragiona-it-ebook-cover.jpg',
    thumb: '/covers/ai-che-ragiona-it-thumb.jpg',
    pages: '280+ pagine full color',
    amazonUrl: AMAZON_IT_URL,
    ctaLabel: 'Acquista su Amazon',
  },
  {
    lang: 'en',
    flag: '🇬🇧',
    label: 'English Edition',
    title: 'AI that Reasons',
    subtitle: 'Building Intelligent Systems with Graphs, RAG and Agents in Production with Python, Neo4j and Microsoft Agent Framework.',
    cover: '/covers/ai-che-ragiona-en-ebook-cover.jpg',
    thumb: '/covers/ai-che-ragiona-en-thumb.jpg',
    pages: '280+ pages full color',
    amazonUrl: AMAZON_EN_URL,
    ctaLabel: 'Buy on Amazon',
  },
];

const parts = [
  { number: 'I', title: 'Fondamenti dei Knowledge Graph', chapters: '1-4', desc: 'Teoria KG, modelli dati (RDF, Property Graph), query Cypher/SPARQL, ontologie OWL e ragionamento' },
  { number: 'II', title: 'Costruire con Python', chapters: '5-12', desc: 'Quick Start in 30 min, architettura, pipeline ingestion, Docker Compose, Pydantic, Vector Store' },
  { number: 'III-V', title: 'RAG, KGC e Pipeline', chapters: '13-20', desc: 'Graph-RAG vs RAG classico, ricerca ibrida, KG Completion, pipeline da testo, metriche qualità' },
  { number: 'VI', title: 'Model Context Protocol', chapters: '21-24', desc: 'Architettura MCP, server per KG, tool custom, sicurezza enterprise, debug' },
  { number: 'VII+', title: 'Agent AI e Business', chapters: '25-32', desc: '7 agenti orchestrati con MAF, confronto framework, pricing, ROI, deployment cloud enterprise' },
];

const stack = ['Python 3.11+', 'C# (.NET 9)', 'Neo4j', 'Redis for AI', 'Ollama', 'FastAPI', 'Docker', 'MCP', 'Microsoft Agent Framework'];

const highlights = [
  { icon: '📖', label: '30+ capitoli + 3 appendici' },
  { icon: '🎨', label: 'Full color' },
  { icon: '💻', label: 'Codice funzionante e testato' },
  { icon: '🏗️', label: 'Architetture reali enterprise' },
  { icon: '🤖', label: 'Multi-agent orchestration' },
  { icon: '🔗', label: 'MCP + Knowledge Graph' },
];

const formats = [
  { icon: '📖', title: 'Paperback', details: ['7" × 10" — Full color', 'Carta bianca premium, copertina lucida'] },
  { icon: '📕', title: 'Hardcover', details: ['7" × 10" — Full color', 'Copertina rigida, dorso stampato'] },
  { icon: '📱', title: 'eBook Kindle', details: ['EPUB 3.0 — Reflowable', 'TOC navigabile, 35 figure'] },
];
---

<BaseLayout
  title="AI che Ragiona — Agent Engineering Studio"
  description="AI che Ragiona: Costruire Sistemi Intelligenti con Grafi, RAG e Agenti in Produzione. Knowledge Graph, Graph-RAG, MCP e Microsoft Agent Framework. Disponibile in italiano e inglese su Amazon."
>
  <main>
    <!-- Hero -->
    <section class="book-hero">
      <div class="container">
        <a href="/" class="back-link">&larr; Agent Engineering Studio</a>

        <div class="book-hero__layout">
          <div class="book-hero__info">
            <span class="badge-new">Aprile 2026</span>
            <h1 class="book-hero__title">
              AI che Ragiona<br/>
              <span class="accent">Sistemi Intelligenti con Grafi, RAG e Agenti</span>
            </h1>
            <p class="book-hero__subtitle">
              Costruire Sistemi Intelligenti con Grafi, RAG e Agenti in Produzione
              con Python, Neo4j e Microsoft Agent Framework.
            </p>
            <p class="book-hero__author">
              di <strong>Giuseppe Zileni</strong> — AI Senior Software Architect @ Hevolus Innovation
            </p>

            <div class="book-hero__editions-label">
              <span class="editions-label">Disponibile in 2 edizioni</span>
            </div>

            <!-- Amazon CTA -->
            <div class="book-hero__actions">
              <a href={AMAZON_IT_URL} target="_blank" rel="noopener noreferrer" class="btn-amazon">
                🇮🇹 Acquista su Amazon
              </a>
              <a href={AMAZON_EN_URL} target="_blank" rel="noopener noreferrer" class="btn-amazon btn-amazon--secondary">
                🇬🇧 Buy on Amazon
              </a>
            </div>
            <div class="book-hero__badge-row">
              <a
                href={AMAZON_IT_URL}
                target="_blank"
                rel="noopener noreferrer"
                aria-label="Available at Amazon"
              >
                <img
                  src="/badges/available_at_amazon_en_horizontal_drk.png"
                  alt="Available at Amazon"
                  class="amazon-badge-img"
                  width="180"
                  height="46"
                  loading="eager"
                />
              </a>
            </div>
            <p class="trademark">
              Amazon's trademark is used under license from Amazon.com, Inc. or its affiliates.
            </p>
          </div>

          <!-- Book cover — real image -->
          <div class="book-hero__cover">
            <div class="cover-3d">
              <img
                src="/covers/ai-che-ragiona-it-ebook-cover.jpg"
                alt="Copertina: AI che Ragiona"
                class="cover-3d__img"
                width="320"
                height="512"
                loading="eager"
              />
            </div>
          </div>
        </div>
      </div>
    </section>

    <!-- Highlights -->
    <section class="highlights">
      <div class="container">
        <div class="highlights__grid">
          {highlights.map((h) => (
            <div class="highlight-item">
              <span class="highlight-item__icon" aria-hidden="true">{h.icon}</span>
              <span class="highlight-item__label">{h.label}</span>
            </div>
          ))}
        </div>
      </div>
    </section>

    <!-- Editions -->
    <section class="editions">
      <div class="container">
        <h2 class="section-title">Edizioni disponibili</h2>
        <div class="editions__grid">
          {editions.map((ed) => (
            <article class="edition-card">
              <div class="edition-card__cover">
                <img
                  src={ed.cover}
                  alt={`Cover: ${ed.title}`}
                  class="edition-card__img"
                  width="400"
                  height="640"
                  loading="lazy"
                />
              </div>
              <div class="edition-card__body">
                <div class="edition-card__lang">
                  <span>{ed.flag}</span>
                  <span>{ed.label}</span>
                </div>
                <h3 class="edition-card__title">{ed.title}</h3>
                <p class="edition-card__desc">{ed.subtitle}</p>
                <p class="edition-card__pages">{ed.pages}</p>
                <a href={ed.amazonUrl} target="_blank" rel="noopener noreferrer" class="btn-amazon btn-amazon--sm">
                  {ed.ctaLabel}
                </a>
              </div>
            </article>
          ))}
        </div>
      </div>
    </section>

    <!-- Description -->
    <section class="description">
      <div class="container">
        <h2 class="section-title">Di cosa parla il libro</h2>
        <div class="description__content">
          <p>
            Questo libro porta il lettore dal concetto di <strong>grafo di conoscenza</strong> fino a un
            sistema funzionante in produzione, capace di rispondere a domande in linguaggio naturale su
            documenti aziendali.
          </p>
          <p>
            Copre l'intero ciclo: modelli dati, ontologie, pipeline RAG, Vector Store, LLM,
            <strong>Model Context Protocol</strong> e orchestrazione <strong>multi-agente</strong>
            con Microsoft Agent Framework.
          </p>
          <p>
            Pensato per <strong>sviluppatori Python e C#</strong>, data engineer e AI engineer che vogliono
            costruire un KG reale, ma anche per <strong>CTO e product manager</strong> che vogliono
            valutare il potenziale dei Knowledge Graph e stimare il ROI.
          </p>
        </div>
      </div>
    </section>

    <!-- Table of contents -->
    <section class="toc">
      <div class="container">
        <h2 class="section-title">Struttura del libro</h2>
        <div class="toc__grid">
          {parts.map((part) => (
            <div class="toc-card">
              <div class="toc-card__header">
                <span class="toc-card__number">Parte {part.number}</span>
                <span class="toc-card__chapters">Cap. {part.chapters}</span>
              </div>
              <h3 class="toc-card__title">{part.title}</h3>
              <p class="toc-card__desc">{part.desc}</p>
            </div>
          ))}
        </div>
      </div>
    </section>

    <!-- Stack -->
    <section class="tech-stack">
      <div class="container">
        <h2 class="section-title">Stack Tecnologico</h2>
        <div class="stack-tags">
          {stack.map((tech) => (
            <span class="stack-tag">{tech}</span>
          ))}
        </div>
      </div>
    </section>

    <!-- Formats -->
    <section class="formats">
      <div class="container">
        <h2 class="section-title">Formati disponibili</h2>
        <div class="formats__grid">
          {formats.map((fmt) => (
            <div class="format-card">
              <span class="format-card__icon" aria-hidden="true">{fmt.icon}</span>
              <h3 class="format-card__title">{fmt.title}</h3>
              {fmt.details.map((d) => (
                <p class="format-card__detail">{d}</p>
              ))}
            </div>
          ))}
        </div>

        <!-- Final Amazon CTA -->
        <div class="formats__cta">
          <a href={AMAZON_IT_URL} target="_blank" rel="noopener noreferrer" class="btn-amazon btn-amazon--lg">
            🇮🇹 Acquista su Amazon
          </a>
          <a href={AMAZON_EN_URL} target="_blank" rel="noopener noreferrer" class="btn-amazon btn-amazon--lg btn-amazon--secondary">
            🇬🇧 Buy on Amazon
          </a>
          <a
            href={AMAZON_IT_URL}
            target="_blank"
            rel="noopener noreferrer"
            aria-label="Available at Amazon"
          >
            <img
              src="/badges/available_at_amazon_en_horizontal_drk.png"
              alt="Available at Amazon"
              class="amazon-badge-img"
              width="180"
              height="46"
              loading="lazy"
            />
          </a>
          <p class="trademark">
            Amazon's trademark is used under license from Amazon.com, Inc. or its affiliates.
          </p>
        </div>
      </div>
    </section>
  </main>
  <Footer />
</BaseLayout>

<style>
  /* ── Back link ── */
  .back-link {
    display: inline-block;
    font-family: var(--font-heading);
    font-size: 0.8rem;
    color: var(--color-text-muted);
    margin-bottom: var(--space-xl);
    transition: color var(--transition-fast);
  }
  .back-link:hover { color: var(--color-accent); }

  /* ── Hero ── */
  .book-hero {
    padding: var(--space-3xl) 0 var(--space-2xl);
  }

  .book-hero__layout {
    display: flex;
    gap: var(--space-3xl);
    align-items: flex-start;
  }

  .book-hero__info {
    flex: 1;
  }

  .badge-new {
    display: inline-block;
    padding: 0.2em 0.8em;
    font-family: var(--font-heading);
    font-size: 0.7rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    color: var(--color-bg);
    background: var(--color-accent);
    border-radius: 999px;
    margin-bottom: var(--space-lg);
  }

  .book-hero__title {
    font-family: var(--font-heading);
    font-size: clamp(1.8rem, 5vw, 2.8rem);
    font-weight: 700;
    line-height: 1.15;
    color: var(--color-text);
    margin-bottom: var(--space-md);
  }

  .accent { color: var(--color-accent); }

  .book-hero__subtitle {
    font-size: clamp(0.95rem, 2vw, 1.15rem);
    color: var(--color-text-muted);
    line-height: 1.6;
    max-width: 560px;
    margin-bottom: var(--space-md);
  }

  .book-hero__author {
    font-size: 0.9rem;
    color: var(--color-text-muted);
    margin-bottom: var(--space-lg);
  }

  .book-hero__author strong {
    color: var(--color-text);
  }

  .book-hero__editions-label {
    margin-bottom: var(--space-md);
  }

  .editions-label {
    font-family: var(--font-heading);
    font-size: 0.75rem;
    color: var(--color-accent);
    text-transform: uppercase;
    letter-spacing: 0.06em;
  }

  /* ── Amazon CTA ── */
  .book-hero__actions {
    display: flex;
    align-items: center;
    gap: var(--space-md);
    flex-wrap: wrap;
    margin-bottom: var(--space-md);
  }

  .book-hero__badge-row {
    margin-bottom: var(--space-sm);
  }

  .btn-amazon {
    display: inline-flex;
    align-items: center;
    gap: var(--space-sm);
    padding: 0.7em 1.6em;
    background: #ff9900;
    color: #0a0e17;
    font-family: var(--font-heading);
    font-size: 0.85rem;
    font-weight: 700;
    border-radius: var(--border-radius);
    text-decoration: none;
    transition: background var(--transition-fast), transform var(--transition-fast), box-shadow var(--transition-fast);
  }

  .btn-amazon:hover {
    background: #ffad33;
    color: #0a0e17;
    transform: translateY(-2px);
    box-shadow: 0 4px 24px rgba(255, 153, 0, 0.35);
  }

  .btn-amazon--secondary {
    background: transparent;
    color: #ff9900;
    border: 1px solid #ff9900;
  }

  .btn-amazon--secondary:hover {
    background: rgba(255, 153, 0, 0.1);
    color: #ffad33;
    border-color: #ffad33;
  }

  .btn-amazon--sm {
    font-size: 0.78rem;
    padding: 0.5em 1.2em;
  }

  .btn-amazon--lg {
    font-size: 1rem;
    padding: 0.8em 2em;
  }

  .amazon-badge-img {
    height: 40px;
    width: auto;
    display: block;
  }

  .trademark {
    font-size: 0.6rem;
    color: var(--color-text-muted);
    opacity: 0.4;
  }

  /* ── Cover 3D ── */
  .book-hero__cover {
    flex-shrink: 0;
  }

  .cover-3d {
    width: 260px;
    perspective: 900px;
  }

  .cover-3d__img {
    width: 100%;
    height: auto;
    border-radius: 4px 12px 12px 4px;
    box-shadow:
      -4px 0 0 rgba(0, 229, 255, 0.15),
      -6px 1px 0 rgba(0, 229, 255, 0.08),
      0 8px 40px rgba(0, 0, 0, 0.5),
      0 0 60px rgba(0, 229, 255, 0.08);
    transform: rotateY(-6deg);
    transition: transform var(--transition-base), box-shadow var(--transition-base);
  }

  .cover-3d:hover .cover-3d__img {
    transform: rotateY(-2deg) translateY(-4px);
    box-shadow:
      -3px 0 0 rgba(0, 229, 255, 0.2),
      -5px 1px 0 rgba(0, 229, 255, 0.12),
      0 12px 48px rgba(0, 0, 0, 0.6),
      0 0 80px rgba(0, 229, 255, 0.12);
  }

  /* ── Highlights ── */
  .highlights {
    padding: var(--space-xl) 0;
    border-top: 1px solid var(--color-border);
    border-bottom: 1px solid var(--color-border);
  }

  .highlights__grid {
    display: flex;
    flex-wrap: wrap;
    justify-content: center;
    gap: var(--space-md);
  }

  .highlight-item {
    display: flex;
    align-items: center;
    gap: var(--space-sm);
    padding: var(--space-sm) var(--space-md);
    background: var(--color-bg-card);
    border: 1px solid var(--color-border);
    border-radius: 999px;
    font-family: var(--font-heading);
    font-size: 0.8rem;
    color: var(--color-text-muted);
  }

  .highlight-item__icon { font-size: 1.1rem; }

  /* ── Editions ── */
  .editions {
    padding: var(--space-3xl) 0;
    border-bottom: 1px solid var(--color-border);
  }

  .editions__grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(340px, 1fr));
    gap: var(--space-xl);
    max-width: 820px;
    margin: 0 auto;
  }

  .edition-card {
    background: var(--color-bg-card);
    border: 1px solid var(--color-border);
    border-radius: var(--border-radius-lg);
    overflow: hidden;
    transition: border-color var(--transition-base), box-shadow var(--transition-base), transform var(--transition-base);
  }

  .edition-card:hover {
    border-color: rgba(0, 229, 255, 0.35);
    box-shadow: 0 0 24px var(--color-accent-glow);
    transform: translateY(-3px);
  }

  .edition-card__cover {
    background: #0a0e1a;
    overflow: hidden;
    max-height: 320px;
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .edition-card__img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: top center;
    transition: transform 0.3s ease;
  }

  .edition-card:hover .edition-card__img {
    transform: scale(1.03);
  }

  .edition-card__body {
    padding: var(--space-lg);
    display: flex;
    flex-direction: column;
    gap: var(--space-sm);
  }

  .edition-card__lang {
    display: flex;
    align-items: center;
    gap: var(--space-xs);
    font-family: var(--font-heading);
    font-size: 0.72rem;
    font-weight: 700;
    color: var(--color-accent);
    text-transform: uppercase;
    letter-spacing: 0.06em;
  }

  .edition-card__title {
    font-family: var(--font-heading);
    font-size: 0.95rem;
    font-weight: 700;
    color: var(--color-text);
    line-height: 1.3;
  }

  .edition-card__desc {
    font-size: 0.82rem;
    color: var(--color-text-muted);
    line-height: 1.6;
  }

  .edition-card__pages {
    font-family: var(--font-heading);
    font-size: 0.72rem;
    color: var(--color-text-muted);
  }

  /* ── Section titles ── */
  .section-title {
    font-family: var(--font-heading);
    font-size: 0.85rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    color: var(--color-accent);
    text-align: center;
    margin-bottom: var(--space-xl);
  }

  /* ── Description ── */
  .description {
    padding: var(--space-3xl) 0;
  }

  .description__content {
    max-width: 680px;
    margin: 0 auto;
  }

  .description__content p {
    font-size: 0.95rem;
    color: var(--color-text-muted);
    line-height: 1.7;
    text-align: center;
    margin-bottom: var(--space-md);
  }

  .description__content strong {
    color: var(--color-text);
  }

  /* ── TOC ── */
  .toc {
    padding: var(--space-2xl) 0 var(--space-3xl);
    border-top: 1px solid var(--color-border);
  }

  .toc__grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: var(--space-md);
    max-width: 720px;
    margin: 0 auto;
  }

  .toc-card {
    background: var(--color-bg-card);
    border: 1px solid var(--color-border);
    border-radius: var(--border-radius-lg);
    padding: var(--space-lg);
    transition: border-color var(--transition-base), box-shadow var(--transition-base);
  }

  .toc-card:hover {
    border-color: rgba(0,229,255,0.3);
    box-shadow: 0 0 16px var(--color-accent-glow);
  }

  .toc-card__header {
    display: flex;
    justify-content: space-between;
    align-items: baseline;
    margin-bottom: var(--space-xs);
  }

  .toc-card__number {
    font-family: var(--font-heading);
    font-size: 0.7rem;
    font-weight: 700;
    color: var(--color-accent);
    text-transform: uppercase;
    letter-spacing: 0.05em;
  }

  .toc-card__chapters {
    font-family: var(--font-heading);
    font-size: 0.75rem;
    color: var(--color-text-muted);
  }

  .toc-card__title {
    font-family: var(--font-heading);
    font-size: 1.05rem;
    font-weight: 600;
    color: var(--color-text);
    margin-bottom: var(--space-xs);
  }

  .toc-card__desc {
    font-size: 0.85rem;
    color: var(--color-text-muted);
    line-height: 1.5;
  }

  /* ── Stack ── */
  .tech-stack {
    padding: var(--space-2xl) 0;
    border-top: 1px solid var(--color-border);
  }

  .stack-tags {
    display: flex;
    flex-wrap: wrap;
    justify-content: center;
    gap: var(--space-sm);
  }

  .stack-tag {
    padding: 0.3em 0.9em;
    font-family: var(--font-heading);
    font-size: 0.8rem;
    color: var(--color-text-muted);
    background: var(--color-bg-card);
    border: 1px solid var(--color-border);
    border-radius: 999px;
    transition: border-color var(--transition-base);
  }

  .stack-tag:hover {
    border-color: rgba(0,229,255,0.3);
    color: var(--color-accent);
  }

  /* ── Formats ── */
  .formats {
    padding: var(--space-2xl) 0 var(--space-3xl);
    border-top: 1px solid var(--color-border);
  }

  .formats__grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: var(--space-lg);
    max-width: 720px;
    margin: 0 auto var(--space-2xl);
  }

  .format-card {
    background: var(--color-bg-card);
    border: 1px solid var(--color-border);
    border-radius: var(--border-radius-lg);
    padding: var(--space-lg);
    text-align: center;
  }

  .format-card__icon { font-size: 2rem; display: block; margin-bottom: var(--space-sm); }
  .format-card__title { font-family: var(--font-heading); font-size: 1rem; font-weight: 700; color: var(--color-text); margin-bottom: var(--space-xs); }
  .format-card__detail { font-size: 0.8rem; color: var(--color-text-muted); line-height: 1.5; }

  .formats__cta {
    text-align: center;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: var(--space-md);
  }

  /* ── Responsive ── */
