---
/*
 * support.astro — Pagina /support
 * Architettura: missione → 3 modi per partecipare → dettagli → milestone → FAQ
 * Per aggiornare i link Stripe: cerca "STRIPE_LINK" e sostituisci con il tuo Payment Link.
 */

import BaseLayout from '../layouts/BaseLayout.astro';
import Footer from '../components/Footer.astro';

const paths = [
  {
    id: 'costruisci',
    icon: '🔧',
    color: 'cta',
    label: 'Costruisci',
    title: 'Entra nel laboratorio',
    tagline: 'Per chi vuole fare, non solo supportare.',
    desc: 'Diventa socio fondatore. Partecipa alle decisioni, porta la tua competenza — qualunque essa sia — e aiuta a costruire qualcosa che dura.',
    cta: 'Scopri come →',
    href: '#costruisci-detail',
  },
  {
    id: 'finanzia',
    icon: '⚡',
    color: 'accent',
    label: 'Finanzia',
    title: 'Tieni vivi i progetti',
    tagline: 'Per chi vuole che questo lavoro esista.',
    desc: 'Le tue donazioni pagano server, workshop e sviluppo. Ogni euro va direttamente a far girare i PoC, formare persone e avanzare verso l\'APS.',
    cta: 'Scegli il tuo livello →',
    href: '#finanzia-detail',
  },
  {
    id: 'collabora',
    icon: '🤝',
    color: 'success',
    label: 'Collabora',
    title: 'Partnership istituzionale',
    tagline: 'Per aziende e Pubblica Amministrazione.',
    desc: 'Co-sviluppa strumenti AI su open data italiani. Ottieni visibilità, workshop dedicati e — con la futura APS — deducibilità fiscale.',
    cta: 'Scrivimi →',
    href: 'mailto:giuseppe.zileni@hevolus.it?subject=Partnership%20%E2%80%94%20Agent%20Engineering%20Studio',
  },
];

const profiles = [
  { icon: '💻', label: 'Sviluppatore / engineer', desc: 'Contribuisci al codice, alle architetture, ai MCP server e ai PoC.' },
  { icon: '📊', label: 'Data scientist / analyst', desc: 'Lavoriamo con open data ISTAT, CKAN, OpenStreetMap — il tuo mondo.' },
  { icon: '⚖️', label: 'Giurista / esperto terzo settore', desc: 'Ci serve chi conosce APS, ETS, RUNTS e il Codice del Terzo Settore.' },
  { icon: '🏛️', label: 'Professionista PA', desc: 'Definisci le specifiche degli strumenti che usi ogni giorno.' },
  { icon: '✍️', label: 'Comunicatore / educator', desc: 'Aiutaci a spiegare AI e open data in italiano, con chiarezza.' },
  { icon: '🎨', label: 'Designer / UX', desc: 'Gli strumenti open devono essere usabili. Il design conta.' },
];

const tiers = [
  {
    emoji: '☕',
    name: 'Caffè',
    price: '5 €',
    cadence: 'una tantum',
    what: 'Una sessione di test su Azure o un\'ora di CDN per i PoC pubblici.',
    perks: ['Nome nella lista Supporter sul sito', 'Newsletter del lab'],
    cta: 'Offri un caffè',
    href: 'https://www.buymeacoffee.com/f9t3zol',
    platform: 'Buy Me a Coffee',
    highlight: false,
  },
  {
    emoji: '🌱',
    name: 'Supporter',
    price: '10 €',
    cadence: '/mese',
    what: 'Copre dominio, CDN e costi base di repository. Il minimo per tenere tutto online.',
    perks: ['Newsletter anticipata con lab notes', 'Badge Supporter su GitHub', 'Canale Discord riservato'],
    cta: 'Diventa Supporter',
    href: 'https://github.com/sponsors/gzileni',
    platform: 'GitHub Sponsors',
    highlight: false,
  },
  {
    emoji: '🔬',
    name: 'Lab Member',
    price: '25 €',
    cadence: '/mese',
    what: 'Un workshop gratuito per 30 persone ogni mese. O un mese di compute per il Knowledge Graph.',
    perks: ['Accesso ai repo privati in anteprima', 'Q&A mensile con Giuseppe', 'Appunti tecnici inediti in PDF', 'Voto sulle priorità dei PoC'],
    cta: 'Diventa Lab Member',
    href: 'https://github.com/sponsors/gzileni',
    platform: 'GitHub Sponsors',
    highlight: true,
  },
  {
    emoji: '🏗️',
    name: 'Builder',
    price: '50 €',
    cadence: '/mese',
    what: 'Un mese completo di server per PA Geo Italia + Knowledge Graph + CI/CD.',
    perks: ['Tutto Lab Member incluso', '1 ora/mese di consulenza tecnica', 'Libri in PDF in anteprima', 'Ringraziamento nei repo e nei libri'],
    cta: 'Diventa Builder',
    href: 'https://github.com/sponsors/gzileni',
    platform: 'GitHub Sponsors',
    highlight: false,
  },
  {
    emoji: '🏛️',
    name: 'Institutional',
    price: '500 €',
    cadence: '/anno',
    what: 'Il pilota PA Geo Italia per il tuo ente, o un workshop privato per il tuo team.',
    perks: ['Logo partner sul sito', 'Workshop privato (mezza giornata)', 'Co-authorship su white paper', 'Progetto dedicato su richiesta', 'Deducibilità fiscale dopo RUNTS'],
    cta: 'Contattami',
    href: 'mailto:giuseppe.zileni@hevolus.it?subject=Institutional%20Partner%20%E2%80%94%20Agent%20Engineering%20Studio',
    platform: 'Fattura via Stripe',
    highlight: false,
  },
];

const milestones = [
  {
    trigger: '3 soci fondatori',
    unlock: 'Costituzione APS',
    desc: 'Con tre soci fondatori Agent Engineering Studio diventa Associazione di Promozione Sociale. Statuto, assemblea costitutiva, codice fiscale dell\'ente. Il laboratorio smette di essere un progetto personale.',
    type: 'people',
    done: false,
  },
  {
    trigger: '10 supporter attivi',
    unlock: 'Infrastruttura stabile',
    desc: 'Server cloud dedicati per tenere sempre online i PoC: Knowledge Graph, PA Geo Italia, Finance AI. Demo sempre accessibili, non solo quando c\'è tempo di farle girare.',
    type: 'money',
    done: false,
  },
  {
    trigger: 'APS costituita + attività stabile',
    unlock: 'Registrazione RUNTS → deducibilità fiscale',
    desc: 'Iscrizione al Registro Unico Nazionale del Terzo Settore. Da questo momento le imprese possono dedurre le donazioni fino al 10% del reddito, le persone fisiche detrarre il 30% (art. 83 D.Lgs. 117/2017).',
    type: 'legal',
    done: false,
  },
  {
    trigger: '1 partner istituzionale',
    unlock: 'PA Geo Italia — primo pilota pubblico',
    desc: 'Co-sviluppo con un ente pubblico pilota: strumento open per interrogare dati territoriali italiani in linguaggio naturale. 100% on-premise, zero lock-in, zero licenze.',
    type: 'partner',
    done: false,
  },
  {
    trigger: '100 supporter attivi',
    unlock: 'AI Agent Day Italia',
    desc: 'Primo evento pubblico in Italia dedicato agli agenti AI: hackathon, talk tecnici, demo dei PoC — ingresso gratuito per tutti i partecipanti.',
    type: 'money',
    done: false,
  },
];
---

<BaseLayout
  title="Partecipa — Agent Engineering Studio"
  description="Costruiamo strumenti AI open source sugli open data italiani. Entra come socio fondatore, sostieni i progetti o collabora istituzionalmente."
  canonical="https://agentengineering.it/support"
>
  <main class="support-page">

    <!-- Back nav -->
    <div class="container back-nav">
      <a href="/" class="back-link">
        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
          <polyline points="15 18 9 12 15 6"/>
        </svg>
        Agent Engineering Studio
      </a>
    </div>

    <!-- Hero -->
    <section class="hero animate-in">
      <div class="container">
        <div class="hero__label">Laboratorio aperto su AI e open data</div>
        <h1 class="hero__title">
          Costruiamo strumenti AI<br/>sugli open data italiani.<br/>
          <span class="hero__title--dim">Insieme.</span>
        </h1>
        <p class="hero__desc">
          Agent Engineering Studio è un laboratorio indipendente: produce proof-of-concept open source,
          libri tecnici e strumenti per la Pubblica Amministrazione usando AI e open data italiani —
          ISTAT, CKAN, OpenStreetMap, dati regionali.
        </p>
        <p class="hero__desc">
          L'obiettivo è diventare un'Associazione di Promozione Sociale.
          Per arrivarci servono persone, risorse e partner. Puoi contribuire in tre modi.
        </p>
      </div>
    </section>

    <!-- 3 paths -->
    <section class="paths-section animate-in animate-delay-1" aria-label="Come partecipare">
      <div class="container">
        <div class="paths-grid">
          {paths.map((p) => (
            <a href={p.href} class={`path-card path-card--${p.color}`}>
              <div class={`path-card__tag path-card__tag--${p.color}`}>{p.label}</div>
              <div class="path-card__icon" aria-hidden="true">{p.icon}</div>
              <div class="path-card__title">{p.title}</div>
              <div class="path-card__tagline">{p.tagline}</div>
              <p class="path-card__desc">{p.desc}</p>
              <div class={`path-card__cta path-card__cta--${p.color}`}>{p.cta}</div>
            </a>
          ))}
        </div>
      </div>
    </section>

    <!-- ── PATH 1: Costruisci ── -->
    <section class="section-detail animate-in animate-delay-2" id="costruisci-detail">
      <div class="container">
        <div class="detail-header detail-header--cta">
          <span class="detail-tag detail-tag--cta">🔧 Costruisci</span>
          <h2 class="detail-title">Diventa socio fondatore</h2>
          <p class="detail-subtitle">
            Servono 3 soci per costituire l'APS. Siamo in 1. Cerchiamo 2 persone
            con qualsiasi background che vogliano essere dentro — non solo finanziatori.
          </p>
        </div>

        <div class="profiles-grid">
          {profiles.map((p) => (
            <div class="profile-card">
              <span class="profile-icon" aria-hidden="true">{p.icon}</span>
              <div class="profile-label">{p.label}</div>
              <div class="profile-desc">{p.desc}</div>
            </div>
          ))}
        </div>

        <div class="founding-ask">
          <div class="founding-ask__col">
            <div class="founding-ask__head">Cosa chiediamo</div>
            <ul>
              <li>Condivisione della missione educativa e open source</li>
              <li>Partecipazione alle assemblee trimestrali (anche online)</li>
              <li>Contributo attivo ad almeno un progetto del laboratorio</li>
              <li>Disponibilità a comparire come socio fondatore nello statuto</li>
            </ul>
          </div>
          <div class="founding-ask__col">
            <div class="founding-ask__head">Cosa ottieni</div>
            <ul>
              <li>Co-decisione su strategia, priorità e uso dei fondi</li>
              <li>Nominato come socio fondatore nel sito e nei documenti</li>
              <li>Accesso completo a tutti i materiali e repo del laboratorio</li>
              <li>Un progetto reale su cui mettere il tuo nome</li>
            </ul>
          </div>
        </div>

        <div class="founding-cta-wrap">
          <a
            href="mailto:giuseppe.zileni@hevolus.it?subject=Socio%20Fondatore%20%E2%80%94%20Agent%20Engineering%20Studio"
            class="btn btn--cta"
          >
            Scrivimi — raccontami chi sei e cosa fai
          </a>
          <p class="founding-hint">
            Nessun requisito tecnico obbligatorio. Serve la voglia di costruire qualcosa insieme.
          </p>
        </div>
      </div>
    </section>

    <!-- ── PATH 2: Finanzia ── -->
    <section class="section-detail animate-in animate-delay-3" id="finanzia-detail">
      <div class="container">
        <div class="detail-header detail-header--accent">
          <span class="detail-tag detail-tag--accent">⚡ Finanzia</span>
          <h2 class="detail-title">Tieni vivi i progetti</h2>
          <p class="detail-subtitle">
            I fondi vanno direttamente a infrastruttura, workshop e sviluppo.
            Non stai donando a un ente astratto: stai rendendo possibili cose concrete.
          </p>
        </div>

        <div class="funds-grid">
          <div class="fund-card">
            <span class="fund-icon" aria-hidden="true">☁️</span>
            <div class="fund-name">Server e cloud</div>
            <div class="fund-desc">Aruba / Azure per tenere sempre online Knowledge Graph, PA Geo Italia e Finance AI</div>
          </div>
          <div class="fund-card">
            <span class="fund-icon" aria-hidden="true">🎓</span>
            <div class="fund-name">Workshop gratuiti</div>
            <div class="fund-desc">Webinar su agenti AI, MCP, Graph-RAG — aperti e gratuiti per la community italiana</div>
          </div>
          <div class="fund-card">
            <span class="fund-icon" aria-hidden="true">📚</span>
            <div class="fund-name">Libri tecnici open</div>
            <div class="fund-desc">Produzione e distribuzione gratuita di volumi su AI engineering, in italiano</div>
          </div>
          <div class="fund-card">
            <span class="fund-icon" aria-hidden="true">🗺️</span>
            <div class="fund-name">PA Geo Italia</div>
            <div class="fund-desc">Strumento open per interrogare dati ISTAT, CKAN e OpenStreetMap — 100% on-premise</div>
          </div>
          <div class="fund-card">
            <span class="fund-icon" aria-hidden="true">🤖</span>
            <div class="fund-name">OPENAgora</div>
            <div class="fund-desc">Civic tech per PA e startup pugliesi sugli open data regionali con agenti AI</div>
          </div>
          <div class="fund-card">
            <span class="fund-icon" aria-hidden="true">🏛️</span>
            <div class="fund-name">Costituzione APS</div>
            <div class="fund-desc">Spese notarili, registrazione RUNTS e avvio formale dell'associazione</div>
          </div>
        </div>

        <div class="tiers-grid">
          {tiers.map((tier) => (
            <div class={`tier-card ${tier.highlight ? 'tier-card--highlight' : ''}`}>
              {tier.highlight && <div class="tier-badge">Più scelto</div>}
              <div class="tier-top">
                <span class="tier-emoji" aria-hidden="true">{tier.emoji}</span>
                <div>
                  <div class="tier-name">{tier.name}</div>
                  <div class="tier-price">
                    {tier.price}<span class="tier-cadence">{tier.cadence}</span>
                  </div>
                </div>
              </div>
              <div class="tier-what">
                <span class="tier-what__label">Cosa rendi possibile</span>
                {tier.what}
              </div>
              <ul class="tier-perks" aria-label={`Vantaggi ${tier.name}`}>
                {tier.perks.map((perk) => (
                  <li class="tier-perk">
                    <span class="tier-perk__check" aria-hidden="true">✓</span>
                    {perk}
                  </li>
                ))}
              </ul>
              <div class="tier-platform">{tier.platform}</div>
              <a
                href={tier.href}
                class={`tier-btn ${tier.highlight ? 'tier-btn--primary' : 'tier-btn--secondary'}`}
                target={tier.href.startsWith('mailto') ? undefined : '_blank'}
                rel={tier.href.startsWith('mailto') ? undefined : 'noopener noreferrer'}
              >
                {tier.cta}
              </a>
            </div>
          ))}
        </div>

        <!-- Platforms -->
        <div class="platforms-strip">
          <div class="platform-item">
            <span class="platform-item__logo platform-item__logo--bmc">☕</span>
            <div>
              <div class="platform-item__name">Buy Me a Coffee</div>
              <a href="https://www.buymeacoffee.com/f9t3zol" target="_blank" rel="noopener noreferrer" class="platform-item__link">buymeacoffee.com/f9t3zol</a>
            </div>
          </div>
          <div class="platform-sep" aria-hidden="true">·</div>
          <div class="platform-item">
            <span class="platform-item__logo platform-item__logo--gh">
              <svg width="18" height="18" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
                <path d="M12 0C5.374 0 0 5.373 0 12c0 5.302 3.438 9.8 8.207 11.387.599.111.793-.261.793-.577v-2.234c-3.338.726-4.033-1.416-4.033-1.416-.546-1.387-1.333-1.756-1.333-1.756-1.089-.745.083-.729.083-.729 1.205.084 1.839 1.237 1.839 1.237 1.07 1.834 2.807 1.304 3.492.997.107-.775.418-1.305.762-1.604-2.665-.305-5.467-1.334-5.467-5.931 0-1.311.469-2.381 1.236-3.221-.124-.303-.535-1.524.117-3.176 0 0 1.008-.322 3.301 1.23A11.509 11.509 0 0 1 12 5.803c1.02.005 2.047.138 3.006.404 2.291-1.552 3.297-1.23 3.297-1.23.653 1.653.242 2.874.118 3.176.77.84 1.235 1.911 1.235 3.221 0 4.609-2.807 5.624-5.479 5.921.43.372.823 1.102.823 2.222v3.293c0 .319.192.694.801.576C20.566 21.797 24 17.3 24 12c0-6.627-5.373-12-12-12z"/>
              </svg>
            </span>
            <div>
              <div class="platform-item__name">GitHub Sponsors</div>
              <a href="https://github.com/sponsors/gzileni" target="_blank" rel="noopener noreferrer" class="platform-item__link">github.com/sponsors/gzileni</a>
            </div>
          </div>
          <div class="platform-sep" aria-hidden="true">·</div>
          <div class="platform-item">
            <span class="platform-item__logo platform-item__logo--stripe">
              <svg width="18" height="18" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
                <path d="M13.976 9.15c-2.172-.806-3.356-1.426-3.356-2.409 0-.831.683-1.305 1.901-1.305 2.227 0 4.515.858 6.09 1.631l.89-5.494C18.252.975 15.697 0 12.165 0 9.667 0 7.589.654 6.104 1.872 4.56 3.147 3.757 4.992 3.757 7.218c0 4.039 2.467 5.76 6.476 7.219 2.585.92 3.445 1.574 3.445 2.583 0 .98-.84 1.545-2.354 1.545-1.875 0-4.965-.921-6.99-2.109l-.9 5.555C5.175 22.99 8.385 24 11.714 24c2.641 0 4.843-.624 6.328-1.813 1.664-1.305 2.525-3.236 2.525-5.732 0-4.128-2.524-5.851-6.591-7.305z"/>
              </svg>
            </span>
            <div>
              <div class="platform-item__name">Stripe — Fattura</div>
              <a href="mailto:giuseppe.zileni@hevolus.it?subject=Institutional%20Partner" class="platform-item__link">Su richiesta per Institutional</a>
            </div>
          </div>
        </div>
      </div>
    </section>

    <!-- ── PATH 3: Collabora (PA + Aziende) ── -->
    <section class="section-detail animate-in animate-delay-4" id="collabora-detail">
      <div class="container">
        <div class="detail-header detail-header--success">
          <span class="detail-tag detail-tag--success">🤝 Collabora</span>
          <h2 class="detail-title">Partnership istituzionale</h2>
          <p class="detail-subtitle">
            Per aziende e PA che vogliono co-costruire strumenti, non solo finanziarli.
          </p>
        </div>

        <div class="collab-grid">
          <div class="collab-card">
            <div class="collab-card__head">💼 Aziende</div>
            <p>
              Workshop privato su agenti AI e MCP per il tuo team (mezza giornata).
              Logo sul sito come partner. Co-authorship su white paper tecnici.
              Con la registrazione RUNTS dell'APS, la quota diventerà fiscalmente
              deducibile fino al 10% del reddito dichiarato.
            </p>
          </div>
          <div class="collab-card">
            <div class="collab-card__head">🏛️ Pubblica Amministrazione</div>
            <p>
              PA Geo Italia è 100% open source e on-premise: i tuoi dati non escono mai dal tuo server.
              Usa solo open data pubblici italiani — ISTAT, CKAN, OpenStreetMap.
              Un ente co-finanziatore ottiene una versione pilota dedicata e voce nelle specifiche funzionali.
            </p>
          </div>
        </div>

        <div style="text-align:center; margin-top: var(--space-xl)">
          <a
            href="mailto:giuseppe.zileni@hevolus.it?subject=Partnership%20%E2%80%94%20Agent%20Engineering%20Studio"
            class="btn btn--success"
          >
            Parliamoci — giuseppe.zileni@hevolus.it
          </a>
        </div>
      </div>
    </section>

    <!-- Milestones -->
    <section class="milestones-section animate-in animate-delay-5">
      <div class="container">
        <h2 class="section-title">La strada verso l'APS</h2>
        <p class="section-subtitle">
          Ogni tappa è trasparente. Quando una viene raggiunta, lo annunciamo sulla newsletter.
        </p>
        <div class="milestones-list" role="list">
          {milestones.map((m, i) => (
            <div class={`milestone-row ${m.done ? 'milestone-row--done' : ''}`} role="listitem">
              <div class="milestone-step" aria-hidden="true">
                <div class={`milestone-dot milestone-dot--${m.type}`}>
                  {m.done ? '✓' : (i + 1)}
                </div>
                {i < milestones.length - 1 && <div class="milestone-line" />}
              </div>
              <div class="milestone-content">
                <div class={`milestone-trigger milestone-trigger--${m.type}`}>{m.trigger}</div>
                <div class="milestone-unlock">→ {m.unlock}</div>
                <div class="milestone-desc">{m.desc}</div>
              </div>
            </div>
          ))}
        </div>
      </div>
    </section>

    <!-- FAQ -->
    <section class="faq-section animate-in animate-delay-6">
      <div class="container">
        <h2 class="section-title">Domande frequenti</h2>
        <div class="faq-list">
          <div class="faq-item">
            <div class="faq-q">A cosa vado a donare, se l'associazione non esiste ancora?</div>
            <div class="faq-a">
              Stai finanziando il lavoro del laboratorio: server, workshop, sviluppo dei PoC e le spese
              per la costituzione dell'APS. Non è una donazione a un ente — è un contributo volontario
              a un progetto educativo open source con obiettivi dichiarati e verificabili.
            </div>
          </div>
          <div class="faq-item">
            <div class="faq-q">Le donazioni sono deducibili fiscalmente?</div>
            <div class="faq-a">
              Al momento no. La deducibilità si attiva in due fasi: prima con la costituzione dell'APS
              (3 soci fondatori), poi con la registrazione RUNTS. Solo dopo il RUNTS le imprese potranno
              dedurre fino al 10% del reddito e le persone fisiche detrarre il 30%
              (art. 83 D.Lgs. 117/2017).
            </div>
          </div>
          <div class="faq-item">
            <div class="faq-q">Non sono sviluppatore. Posso diventare socio fondatore?</div>
            <div class="faq-a">
              Sì, esplicitamente. Cerchiamo competenze diverse: giuristi, esperti di PA, comunicatori,
              designer, educator, data analyst. Un laboratorio che produce strumenti per la PA e la
              community ha bisogno di persone che conoscono quei mondi dall'interno.
            </div>
          </div>
          <div class="faq-item">
            <div class="faq-q">Posso cancellare l'abbonamento mensile?</div>
            <div class="faq-a">
              Sì, in qualsiasi momento senza penali. GitHub Sponsors e Buy Me a Coffee permettono di
              gestire o cancellare l'abbonamento direttamente dalla propria dashboard.
            </div>
          </div>
