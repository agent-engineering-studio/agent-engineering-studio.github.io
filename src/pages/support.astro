---
/*
 * support.astro — Pagina /support
 * Tier di supporto, milestone, piattaforme (BMC, GitHub Sponsors, Stripe), FAQ.
 * Per aggiornare i link Stripe: cerca "STRIPE_LINK" e sostituisci con il tuo Payment Link.
 */

import BaseLayout from '../layouts/BaseLayout.astro';
import Footer from '../components/Footer.astro';

const tiers = [
  {
    emoji: '☕',
    name: 'Caffè',
    price: '5 €',
    cadence: 'una tantum',
    desc: 'Il gesto più semplice. Grazie per un articolo, un libro, un repo che ti ha fatto risparmiare tempo.',
    perks: [
      'Nome nella lista Supporter sul sito',
      'Accesso alla newsletter del lab',
    ],
    cta: 'Offri un caffè',
    href: 'https://www.buymeacoffee.com/f9t3zol',
    platform: 'Buy Me a Coffee',
    highlight: false,
  },
  {
    emoji: '🌱',
    name: 'Supporter',
    price: '10 €',
    cadence: '/mese',
    desc: 'Fai parte della community che tiene vivo il laboratorio. Ogni mese.',
    perks: [
      'Newsletter anticipata con lab notes',
      'Badge Supporter su GitHub',
      'Accesso al canale Discord riservato',
    ],
    cta: 'Diventa Supporter',
    href: 'https://github.com/sponsors/gzileni',
    platform: 'GitHub Sponsors',
    highlight: false,
  },
  {
    emoji: '🔬',
    name: 'Lab Member',
    price: '25 €',
    cadence: '/mese',
    desc: 'Accesso privilegiato ai lavori in corso: repo privati, anteprime e sessioni Q&A mensili.',
    perks: [
      'Accesso anticipato ai repo privati',
      'Sessioni mensili Q&A con Giuseppe',
      'PDF degli appunti tecnici inediti',
      'Voto sulle priorità dei prossimi PoC',
    ],
    cta: 'Diventa Lab Member',
    href: 'https://github.com/sponsors/gzileni',
    platform: 'GitHub Sponsors',
    highlight: true,
  },
  {
    emoji: '🏗️',
    name: 'Builder',
    price: '50 €',
    cadence: '/mese',
    desc: 'Per chi usa il lavoro del lab nei propri progetti professionali e vuole un collegamento diretto.',
    perks: [
      'Tutto Lab Member incluso',
      '1 ora/mese di consulenza tecnica',
      'Copia anticipata dei libri in PDF',
      'Ringraziamento nei repo e nei libri',
    ],
    cta: 'Diventa Builder',
    href: 'https://github.com/sponsors/gzileni',
    platform: 'GitHub Sponsors',
    highlight: false,
  },
  {
    emoji: '🏛️',
    name: 'Institutional Partner',
    price: '500 €',
    cadence: '/anno',
    desc: 'Per aziende, PA ed enti che vogliono co-costruire, avere visibilità e partecipare attivamente.',
    perks: [
      'Logo come partner sul sito',
      'Co-authorship su white paper',
      'Workshop privato per il team (mezza giornata)',
      'Progetto dedicato su richiesta',
      'Potenziale deducibilità fiscale (ETS in arrivo)',
    ],
    cta: 'Contatta per partnership',
    href: 'mailto:giuseppe.zileni@hevolus.it?subject=Institutional%20Partner%20%E2%80%94%20Agent%20Engineering%20Studio',
    platform: 'Contatto diretto + fattura',
    highlight: false,
  },
];

const milestones = [
  {
    supporters: '10 supporter attivi',
    unlock: 'Demo live sempre online',
    desc: 'Infrastruttura cloud (Aruba / Azure) per tenere i PoC pubblici sempre accessibili — Knowledge Graph, PA Geo Italia, Finance AI.',
    done: false,
  },
  {
    supporters: '25 supporter attivi',
    unlock: 'Workshop mensili gratuiti',
    desc: 'Webinar aperti alla community italiana su agenti AI, MCP server, Graph-RAG e orchestrazione multi-agent.',
    done: false,
  },
  {
    supporters: '50 supporter attivi',
    unlock: 'Costituzione APS',
    desc: 'Agent Engineering Studio diventa Associazione di Promozione Sociale: le donazioni di imprese diventano deducibili fino al 10% del reddito dichiarato, quelle di persone fisiche detraibili al 30%.',
    done: false,
  },
  {
    supporters: '100 supporter attivi',
    unlock: 'AI Agent Day Italia',
    desc: 'Primo evento pubblico dedicato agli agenti AI in Italia: hackathon, talk tecnici, demo dei PoC — ingresso gratuito per i partecipanti.',
    done: false,
  },
  {
    supporters: '1 partner istituzionale',
    unlock: 'PA Geo Italia — Pilota pubblico',
    desc: 'Co-sviluppo con un ente pubblico pilota dello strumento open per interrogare dati territoriali italiani (ISTAT, CKAN, OpenStreetMap) in linguaggio naturale. 100% on-premise, sovranità del dato garantita.',
    done: false,
  },
];
---

<BaseLayout
  title="Supporta il laboratorio — Agent Engineering Studio"
  description="Sostieni il laboratorio aperto su agenti AI: proof-of-concept open source, libri tecnici, strumenti per la PA e la community italiana. Tier da 5€ a partner istituzionale."
  canonical="https://agentengineering.it/support"
>
  <main class="support-page">

    <!-- Back nav -->
    <div class="container back-nav">
      <a href="/" class="back-link">
        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
          <polyline points="15 18 9 12 15 6"/>
        </svg>
        Agent Engineering Studio
      </a>
    </div>

    <!-- Hero -->
    <section class="support-hero animate-in">
      <div class="container">
        <div class="support-hero__label">Supporta il laboratorio</div>
        <h1 class="support-hero__title">Costruito in aperto.<br/>Sostenuto dalla community.</h1>
        <p class="support-hero__desc">
          Agent Engineering Studio è un laboratorio indipendente: niente VC, niente paywall, niente sponsor nascosti.
          Produce proof-of-concept aperti, libri tecnici, strumenti per la Pubblica Amministrazione
          e materiale formativo gratuito sugli agenti AI.
        </p>
        <p class="support-hero__desc">
          Se qualcosa di quello che trovi qui ti è stato utile — un repo, un libro, un MCP server —
          considera di sostenere il lavoro. Ogni contributo va direttamente a infrastruttura, eventi e nuovi progetti.
        </p>
      </div>
    </section>

    <!-- Use of funds -->
    <section class="use-of-funds animate-in animate-delay-1">
      <div class="container">
        <h2 class="section-title">A cosa servono i fondi</h2>
        <div class="funds-grid">
          <div class="fund-card">
            <span class="fund-icon" aria-hidden="true">☁️</span>
            <div class="fund-name">Infrastruttura cloud</div>
            <div class="fund-desc">Aruba / Azure per hosting, CI/CD e container runtime dei PoC pubblici</div>
          </div>
          <div class="fund-card">
            <span class="fund-icon" aria-hidden="true">📚</span>
            <div class="fund-name">Libri & contenuti</div>
            <div class="fund-desc">Produzione e stampa di nuovi volumi tecnici, parte rilasciata gratuitamente alla community</div>
          </div>
          <div class="fund-card">
            <span class="fund-icon" aria-hidden="true">🎓</span>
            <div class="fund-name">Workshop gratuiti</div>
            <div class="fund-desc">Formazione aperta su agenti AI, MCP, Graph-RAG — gratuita per studenti e PA</div>
          </div>
          <div class="fund-card">
            <span class="fund-icon" aria-hidden="true">🗺️</span>
            <div class="fund-name">PA Geo Italia</div>
            <div class="fund-desc">Strumento open per interrogare dati ISTAT, CKAN e OpenStreetMap in linguaggio naturale</div>
          </div>
          <div class="fund-card">
            <span class="fund-icon" aria-hidden="true">🤝</span>
            <div class="fund-name">OPENAgora</div>
            <div class="fund-desc">Civic tech per startup e PA che sfruttano gli open data regionali con agenti AI</div>
          </div>
          <div class="fund-card">
            <span class="fund-icon" aria-hidden="true">🎪</span>
            <div class="fund-name">Evento community</div>
            <div class="fund-desc">AI Agent Day: hackathon, talk tecnici e demo — aperto e gratuito per i partecipanti</div>
          </div>
        </div>
      </div>
    </section>

    <!-- Tiers -->
    <section class="tiers-section animate-in animate-delay-2">
      <div class="container">
        <h2 class="section-title">Scegli il tuo livello di supporto</h2>
        <div class="tiers-grid">
          {tiers.map((tier) => (
            <div class={`tier-card ${tier.highlight ? 'tier-card--highlight' : ''}`}>
              {tier.highlight && <div class="tier-badge">Più scelto</div>}
              <div class="tier-emoji" aria-hidden="true">{tier.emoji}</div>
              <div class="tier-name">{tier.name}</div>
              <div class="tier-price">
                {tier.price}<span class="tier-cadence">{tier.cadence}</span>
              </div>
              <p class="tier-desc">{tier.desc}</p>
              <ul class="tier-perks" aria-label={`Vantaggi ${tier.name}`}>
                {tier.perks.map((perk) => (
                  <li class="tier-perk">
                    <span class="tier-perk__check" aria-hidden="true">✓</span>
                    {perk}
                  </li>
                ))}
              </ul>
              <div class="tier-platform">{tier.platform}</div>
              <a
                href={tier.href}
                class={`tier-btn ${tier.highlight ? 'tier-btn--primary' : 'tier-btn--secondary'}`}
                target={tier.href.startsWith('mailto') ? undefined : '_blank'}
                rel={tier.href.startsWith('mailto') ? undefined : 'noopener noreferrer'}
              >
                {tier.cta}
              </a>
            </div>
          ))}
        </div>
      </div>
    </section>

    <!-- Platforms -->
    <section class="platforms-section animate-in animate-delay-3">
      <div class="container">
        <h2 class="section-title">Come supportare</h2>
        <div class="platforms-grid">
          <div class="platform-card">
            <div class="platform-logo platform-logo--bmc" aria-hidden="true">☕</div>
            <div class="platform-name">Buy Me a Coffee</div>
            <div class="platform-desc">Contributi una tantum rapidi. Zero iscrizioni. Ideale per il tier Caffè o per supporto occasionale.</div>
            <a href="https://www.buymeacoffee.com/f9t3zol" target="_blank" rel="noopener noreferrer" class="platform-link">
              buymeacoffee.com/f9t3zol →
            </a>
          </div>
          <div class="platform-card">
            <div class="platform-logo platform-logo--gh" aria-hidden="true">
              <svg width="28" height="28" viewBox="0 0 24 24" fill="currentColor">
                <path d="M12 0C5.374 0 0 5.373 0 12c0 5.302 3.438 9.8 8.207 11.387.599.111.793-.261.793-.577v-2.234c-3.338.726-4.033-1.416-4.033-1.416-.546-1.387-1.333-1.756-1.333-1.756-1.089-.745.083-.729.083-.729 1.205.084 1.839 1.237 1.839 1.237 1.07 1.834 2.807 1.304 3.492.997.107-.775.418-1.305.762-1.604-2.665-.305-5.467-1.334-5.467-5.931 0-1.311.469-2.381 1.236-3.221-.124-.303-.535-1.524.117-3.176 0 0 1.008-.322 3.301 1.23A11.509 11.509 0 0 1 12 5.803c1.02.005 2.047.138 3.006.404 2.291-1.552 3.297-1.23 3.297-1.23.653 1.653.242 2.874.118 3.176.77.84 1.235 1.911 1.235 3.221 0 4.609-2.807 5.624-5.479 5.921.43.372.823 1.102.823 2.222v3.293c0 .319.192.694.801.576C20.566 21.797 24 17.3 24 12c0-6.627-5.373-12-12-12z"/>
              </svg>
            </div>
            <div class="platform-name">GitHub Sponsors</div>
            <div class="platform-desc">Abbonamenti mensili con tier. Perfetto per Supporter, Lab Member e Builder. Gestione semplice dal tuo account GitHub.</div>
            <a href="https://github.com/sponsors/gzileni" target="_blank" rel="noopener noreferrer" class="platform-link">
              github.com/sponsors/gzileni →
            </a>
          </div>
          <div class="platform-card">
            <div class="platform-logo platform-logo--stripe" aria-hidden="true">
              <svg width="28" height="28" viewBox="0 0 24 24" fill="currentColor">
                <path d="M13.976 9.15c-2.172-.806-3.356-1.426-3.356-2.409 0-.831.683-1.305 1.901-1.305 2.227 0 4.515.858 6.09 1.631l.89-5.494C18.252.975 15.697 0 12.165 0 9.667 0 7.589.654 6.104 1.872 4.56 3.147 3.757 4.992 3.757 7.218c0 4.039 2.467 5.76 6.476 7.219 2.585.92 3.445 1.574 3.445 2.583 0 .98-.84 1.545-2.354 1.545-1.875 0-4.965-.921-6.99-2.109l-.9 5.555C5.175 22.99 8.385 24 11.714 24c2.641 0 4.843-.624 6.328-1.813 1.664-1.305 2.525-3.236 2.525-5.732 0-4.128-2.524-5.851-6.591-7.305z"/>
              </svg>
            </div>
            <div class="platform-name">Stripe — Fattura</div>
            <div class="platform-desc">Per aziende e PA che necessitano di fattura. Riservato al tier Institutional Partner. Pagamento sicuro con emissione fattura.</div>
            <a href="mailto:giuseppe.zileni@hevolus.it?subject=Institutional%20Partner%20%E2%80%94%20Agent%20Engineering%20Studio" class="platform-link">
              Richiedi link di pagamento →
            </a>
          </div>
        </div>
      </div>
    </section>

    <!-- Milestones -->
    <section class="milestones-section animate-in animate-delay-4">
      <div class="container">
        <h2 class="section-title">Milestone — Cosa sbloccheremo insieme</h2>
        <p class="section-subtitle">
          Il supporto collettivo sblocca obiettivi concreti. Ogni milestone è trasparente e verificabile.
          Quando una viene raggiunta, lo annunciamo sulla newsletter e sul sito.
        </p>
        <div class="milestones-list" role="list">
          {milestones.map((m, i) => (
            <div class={`milestone-row ${m.done ? 'milestone-row--done' : ''}`} role="listitem">
              <div class="milestone-step" aria-hidden="true">
                <div class="milestone-dot">{m.done ? '✓' : (i + 1)}</div>
                {i < milestones.length - 1 && <div class="milestone-line" />}
              </div>
              <div class="milestone-content">
                <div class="milestone-trigger">{m.supporters}</div>
                <div class="milestone-unlock">→ {m.unlock}</div>
                <div class="milestone-desc">{m.desc}</div>
              </div>
            </div>
          ))}
        </div>
      </div>
    </section>

    <!-- Institutional -->
    <section class="institutional-section animate-in animate-delay-5">
      <div class="container">
        <div class="institutional-card">
          <h2 class="institutional-title">Per aziende e Pubblica Amministrazione</h2>
          <p class="institutional-desc">
            Il tier Institutional Partner è una collaborazione concreta, non una donazione generica.
            Pensato per CEO, CTO e dirigenti di ente pubblico che vogliono partecipare attivamente.
          </p>
          <div class="institutional-grid">
            <div class="institutional-item">
              <div class="institutional-item__head">💼 Aziende</div>
              <p>
                Workshop privato per il tuo team su agenti AI e MCP (mezza giornata).
                Logo sul sito come partner. Co-authorship su white paper tecnici.
                Consulenza tecnica prioritaria. Con la futura APS, la quota è
                fiscalmente deducibile per le imprese fino al 10% del reddito dichiarato.
              </p>
            </div>
            <div class="institutional-item">
              <div class="institutional-item__head">🏛️ Pubblica Amministrazione</div>
              <p>
                PA Geo Italia è 100% open source, on-premise, a sovranità del dato garantita.
                Nessuna dipendenza da cloud USA. Usa solo open data italiani: ISTAT, CKAN, OpenStreetMap.
                Un ente che co-finanzia il progetto ottiene una versione pilota dedicata
                e il diritto di contribuire alle specifiche funzionali.
              </p>
            </div>
          </div>
          <a
            href="mailto:giuseppe.zileni@hevolus.it?subject=Institutional%20Partner%20%E2%80%94%20Agent%20Engineering%20Studio"
            class="institutional-cta"
          >
            Parliamoci — scrivi a giuseppe.zileni@hevolus.it
          </a>
        </div>
      </div>
    </section>

    <!-- FAQ -->
    <section class="faq-section animate-in animate-delay-6">
      <div class="container">
        <h2 class="section-title">Domande frequenti</h2>
        <div class="faq-list">
          <div class="faq-item">
            <div class="faq-q">Le donazioni sono deducibili fiscalmente?</div>
            <div class="faq-a">
              Al momento no, poiché il laboratorio opera come persona fisica.
              Quando raggiungeremo i 50 supporter attiveremo la costituzione dell'APS
              (Associazione di Promozione Sociale): da quel momento le imprese potranno
              dedurre le donazioni fino al 10% del reddito dichiarato,
              e le persone fisiche detrarre il 30% di quanto donato (art. 83 D.Lgs. 117/2017).
            </div>
          </div>
          <div class="faq-item">
            <div class="faq-q">Posso cancellare l'abbonamento mensile in qualsiasi momento?</div>
            <div class="faq-a">
              Sì, senza penali. GitHub Sponsors e Buy Me a Coffee permettono di
              gestire o cancellare l'abbonamento direttamente dalla propria dashboard
              senza preavviso.
            </div>
          </div>
          <div class="faq-item">
            <div class="faq-q">Il codice rimarrà open source anche con i fondi?</div>
            <div class="faq-a">
              Sì, senza eccezioni. Tutti i repository esistenti e futuri restano
              pubblicati con licenza Apache 2.0 su GitHub. Il supporto finanziario
              non cambia la natura open del laboratorio — la accelera.
            </div>
          </div>
          <div class="faq-item">
            <div class="faq-q">Come funziona il tier Institutional per la PA?</div>
            <div class="faq-a">
              Il pagamento avviene tramite link Stripe con emissione di fattura.
              Per enti pubblici che necessitano di un contratto formale,
              possiamo strutturare un accordo di collaborazione.
              Scrivi a giuseppe.zileni@hevolus.it con oggetto "Institutional Partner"
              e descrivi il tuo ente e le tue esigenze.
            </div>
          </div>
          <div class="faq-item">
            <div class="faq-q">Cos'è PA Geo Italia e perché è rilevante per un comune?</div>
            <div class="faq-a">
              PA Geo Italia è uno strumento open source che permette agli impiegati
              comunali di fare domande in linguaggio naturale sui dati territoriali italiani
              (ISTAT, CKAN, OpenStreetMap) e ottenere mappe, tabelle e report.
              Gira completamente on-premise in Docker Compose: i dati non escono mai dal tuo server.
              Zero licenze, zero cloud USA, zero lock-in.
            </div>
          </div>
        </div>
      </div>
    </section>

  </main>
  <Footer />
</BaseLayout>

<style>
  .support-page {
    min-height: 100vh;
  }

  /* ── Back nav ── */
  .back-nav {
    padding-top: var(--space-xl);
    padding-bottom: 0;
  }

  .back-link {
    display: inline-flex;
    align-items: center;
    gap: 0.4rem;
    color: var(--color-text-muted);
    font-size: 0.85rem;
    text-decoration: none;
    transition: color var(--transition-fast);
  }

  .back-link:hover { color: var(--color-accent); }

  /* ── Hero ── */
  .support-hero {
    padding: var(--space-2xl) 0 var(--space-xl);
    text-align: center;
  }

  .support-hero__label {
    display: inline-block;
    font-family: var(--font-heading);
    font-size: 0.75rem;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: var(--color-accent);
    margin-bottom: var(--space-md);
    padding: 0.3rem 0.8rem;
    border: 1px solid rgba(33, 150, 243, 0.3);
    border-radius: 4px;
  }

  .support-hero__title {
    font-family: var(--font-heading);
    font-size: clamp(1.8rem, 4vw, 2.6rem);
    font-weight: 700;
    color: var(--color-text);
    line-height: 1.25;
    margin-bottom: var(--space-lg);
  }

  .support-hero__desc {
    max-width: 620px;
    margin: 0 auto var(--space-md);
    font-size: 1rem;
    color: var(--color-text-muted);
    line-height: 1.7;
  }

  /* ── Section titles ── */
  .section-title {
    font-family: var(--font-heading);
    font-size: 1.3rem;
    font-weight: 700;
    color: var(--color-text);
    margin-bottom: var(--space-md);
    text-align: center;
  }

  .section-subtitle {
    text-align: center;
    color: var(--color-text-muted);
    font-size: 0.95rem;
    max-width: 560px;
    margin: 0 auto var(--space-xl);
    line-height: 1.6;
  }

  /* ── Use of funds ── */
  .use-of-funds { padding: var(--space-2xl) 0; }

  .funds-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(240px, 1fr));
    gap: var(--space-md);
    margin-top: var(--space-xl);
  }

  .fund-card {
    background: var(--color-bg-card);
    border: 1px solid var(--color-border);
    border-radius: var(--border-radius-lg);
    padding: var(--space-lg);
  }

  .fund-icon { font-size: 1.5rem; display: block; margin-bottom: var(--space-sm); }
  .fund-name { font-weight: 600; font-size: 0.9rem; color: var(--color-text); margin-bottom: var(--space-xs); }
  .fund-desc { font-size: 0.8rem; color: var(--color-text-muted); line-height: 1.5; }

  /* ── Tiers ── */
  .tiers-section { padding: var(--space-2xl) 0; }

  .tiers-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(200px, 1fr));
    gap: var(--space-md);
    margin-top: var(--space-xl);
    align-items: start;
  }

  .tier-card {
    background: var(--color-bg-card);
    border: 1px solid var(--color-border);
    border-radius: var(--border-radius-lg);
    padding: var(--space-lg);
    position: relative;
    display: flex;
    flex-direction: column;
    gap: var(--space-sm);
  }

  .tier-card--highlight {
    border-color: var(--color-accent);
    background: rgba(33, 150, 243, 0.06);
  }

  .tier-badge {
    position: absolute;
    top: -10px;
    left: 50%;
    transform: translateX(-50%);
    background: var(--color-accent);
    color: #fff;
    font-family: var(--font-heading);
    font-size: 0.65rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    padding: 2px 10px;
    border-radius: 4px;
    white-space: nowrap;
  }

  .tier-emoji { font-size: 1.8rem; }

  .tier-name {
    font-family: var(--font-heading);
    font-size: 0.9rem;
    font-weight: 700;
    color: var(--color-text);
  }

  .tier-price {
    font-size: 1.5rem;
    font-weight: 800;
    color: var(--color-accent);
    font-family: var(--font-heading);
  }

  .tier-cadence {
