---
/*
 * support.astro — Redirect alla home.
 * La pagina /support precedente (tier sponsor, founding member, APS) è stata
 * rimossa nel riposizionamento del sito come spazio di studio personale.
 * Manteniamo solo il redirect per non spezzare link esterni o cache.
 */
const target = '/';
---

<!doctype html>
<html lang="it">
  <head>
    <meta charset="utf-8" />
    <title>Agent Engineering Studio</title>
    <meta http-equiv="refresh" content={`0; url=${target}`} />
    <link rel="canonical" href="https://agentengineering.it/" />
    <meta name="robots" content="noindex" />
  </head>
  <body>
    <p>Reindirizzamento in corso. Se il browser non ti reindirizza automaticamente, <a href={target}>vai alla home</a>.</p>
  </body>
</html>
