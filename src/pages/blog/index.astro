---
/*
 * blog/index.astro — Lista articoli del blog
 * Astro 5 Content Layer API. Aggiungere post in src/content/blog/
 */

import BaseLayout from '../../layouts/BaseLayout.astro';
import Footer from '../../components/Footer.astro';
import { getCollection } from 'astro:content';

const allPosts = (await getCollection('blog', ({ data }) => !data.draft))
  .sort((a, b) => b.data.pubDate.getTime() - a.data.pubDate.getTime());

const formatDate = (d: Date) =>
  d.toLocaleDateString('it-IT', { year: 'numeric', month: 'long', day: 'numeric' });
---

<BaseLayout
  title="Blog — Agent Engineering Studio"
  description="Tutorial, riflessioni e aggiornamenti su agenti AI, open data e civic tech dal laboratorio Agent Engineering Studio."
  canonical="https://agentengineering.it/blog"
>
  <header class="blog-header">
    <div class="container">
      <a href="/" class="back-link">&larr; Home</a>
      <h1 class="blog-title">Blog</h1>
      <p class="blog-subtitle">Tutorial, riflessioni e aggiornamenti dal laboratorio</p>
    </div>
  </header>

  <main class="container">
    {allPosts.length === 0 && (
      <p class="empty">Nessun articolo ancora. Torna presto!</p>
    )}

    <ul class="post-list">
      {allPosts.map(post => (
        <li class="post-card">
          <a href={`/blog/${post.slug}`} class="post-card__link">
            <div class="post-card__meta">
              <time datetime={post.data.pubDate.toISOString()}>
                {formatDate(post.data.pubDate)}
              </time>
              {post.data.tags.slice(0, 3).map(tag => (
                <span class="tag">{tag}</span>
              ))}
            </div>
            <h2 class="post-card__title">{post.data.title}</h2>
            <p class="post-card__desc">{post.data.description}</p>
            <span class="post-card__cta">Leggi &rarr;</span>
          </a>
        </li>
      ))}
    </ul>
  </main>

  <Footer />
</BaseLayout>

<style>
  .blog-header {
    padding: var(--space-2xl) 0 var(--space-xl);
    border-bottom: 1px solid var(--color-border);
    margin-bottom: var(--space-2xl);
  }

  .back-link {
    font-size: 0.85rem;
    color: var(--color-text-muted);
    text-decoration: none;
    display: inline-block;
    margin-bottom: var(--space-md);
    transition: color var(--transition-fast);
  }
  .back-link:hover { color: var(--color-accent); }

  .blog-title {
    font-family: var(--font-heading);
    font-size: clamp(2rem, 5vw, 3rem);
    font-weight: 700;
    color: var(--color-text);
    margin-bottom: var(--space-xs);
  }

  .blog-subtitle {
    color: var(--color-text-muted);
    font-size: 1.1rem;
  }

  .post-list {
    list-style: none;
    padding: 0;
    margin: 0 0 var(--space-2xl);
    display: flex;
    flex-direction: column;
    gap: var(--space-lg);
  }

  .post-card {
    border: 1px solid var(--color-border);
    border-radius: 12px;
    overflow: hidden;
    transition: border-color var(--transition-base), transform var(--transition-base);
  }
  .post-card:hover {
    border-color: var(--color-accent);
    transform: translateY(-2px);
  }

  .post-card__link {
    display: block;
    padding: var(--space-xl);
    text-decoration: none;
    color: inherit;
  }

  .post-card__meta {
    display: flex;
    align-items: center;
    gap: var(--space-sm);
    flex-wrap: wrap;
    margin-bottom: var(--space-sm);
  }

  .post-card__meta time {
    font-size: 0.8rem;
    color: var(--color-text-muted);
    font-family: var(--font-mono);
  }

  .tag {
    font-size: 0.7rem;
    font-family: var(--font-mono);
    color: var(--color-accent);
    background: rgba(33,150,243,0.1);
    border: 1px solid rgba(33,150,243,0.2);
    border-radius: 4px;
    padding: 2px 6px;
  }

  .post-card__title {
    font-family: var(--font-heading);
    font-size: 1.3rem;
    font-weight: 600;
    color: var(--color-text);
    margin-bottom: var(--space-sm);
    line-height: 1.3;
  }

  .post-card__desc {
    color: var(--color-text-muted);
    font-size: 0.95rem;
    line-height: 1.6;
    margin-bottom: var(--space-md);
  }

  .post-card__cta {
    font-size: 0.85rem;
    font-weight: 600;
    color: var(--color-accent);
  }

  .empty {
    text-align: center;
    color: var(--color-text-muted);
    padding: var(--space-2xl) 0;
  }
</style>

