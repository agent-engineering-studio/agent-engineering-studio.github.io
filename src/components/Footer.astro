---
/*
 * Footer.astro — Footer minimal
 * Per modificare i link o il testo: aggiorna l'HTML qui sotto.
 */
---

<footer class="footer">
  <div class="container">
    <div class="footer__logo">
      <img src="/logo-icon.png" alt="Agent Engineering Studio" class="footer__logo-img" width="40" height="40" />
    </div>
    <p class="footer__copy">&copy; 2025–2026 Agent Engineering Studio</p>
    <p class="footer__meta">
      Built with <a href="https://astro.build" target="_blank" rel="noopener noreferrer">Astro</a>
      &middot; Hosted on <a href="https://pages.github.com" target="_blank" rel="noopener noreferrer">GitHub Pages</a>
    </p>
    <p class="footer__links">
      <a href="/support" class="footer__link footer__link--support">&#10084;&#65039; Supporta il progetto</a>
      <span class="footer__sep" aria-hidden="true">&middot;</span>
      <a href="#" class="footer__link">Privacy Policy</a>
    </p>
  </div>
</footer>

<style>
  .footer {
    padding: var(--space-2xl) 0;
    text-align: center;
    border-top: 1px solid var(--color-border);
  }

  .footer__logo {
    display: flex;
    justify-content: center;
    margin-bottom: var(--space-md);
  }

  .footer__logo-img {
    width: 80px;
    height: 80px;
    border-radius: 8px;
    opacity: 0.7;
    transition: opacity var(--transition-base);
  }

  .footer__logo-img:hover {
    opacity: 1;
  }

  .footer__copy {
    font-family: var(--font-heading);
    font-size: 0.85rem;
    color: var(--color-text-muted);
    margin-bottom: var(--space-xs);
  }

  .footer__meta {
    font-size: 0.8rem;
    color: var(--color-text-muted);
    margin-bottom: var(--space-sm);
  }

  .footer__meta a {
    color: var(--color-text-muted);
    text-decoration: underline;
    text-underline-offset: 2px;
  }

  .footer__meta a:hover {
    color: var(--color-accent);
  }

  .footer__links {
    font-size: 0.8rem;
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 0.5rem;
    flex-wrap: wrap;
  }

  .footer__sep {
    color: var(--color-border);
  }

  .footer__link {
    color: var(--color-text-muted);
    text-decoration: underline;
    text-underline-offset: 2px;
    transition: color var(--transition-fast);
  }

  .footer__link:hover {
    color: var(--color-accent);
  }

  .footer__link--support {
    color: var(--color-cta);
    font-weight: 600;
    text-decoration: none;
  }

  .footer__link--support:hover {
    color: var(--color-cta-hover);
  }
</style>
