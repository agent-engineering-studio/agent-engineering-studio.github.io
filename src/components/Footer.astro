---
/*
 * Footer.astro — Footer minimal
 * Per modificare i link o il testo: aggiorna i blocchi qui sotto.
 */
interface Props {
  lang?: 'it' | 'en';
}
const { lang = 'it' } = Astro.props;

const t = {
  it: {
    blog: 'Blog',
    github: 'GitHub',
    privacy: 'Privacy Policy',
    builtWith: 'Built with',
    hostedOn: 'Hosted on',
    blogHref: '/blog',
  },
  en: {
    blog: 'Blog',
    github: 'GitHub',
    privacy: 'Privacy Policy',
    builtWith: 'Built with',
    hostedOn: 'Hosted on',
    blogHref: '/en/blog',
  },
}[lang];
---

<footer class="footer">
  <div class="container">
    <div class="footer__logo">
      <img src="/logo-icon.png" alt="Agent Engineering Studio" class="footer__logo-img" width="40" height="40" />
    </div>
    <p class="footer__copy">&copy; 2025&ndash;2026 Agent Engineering Studio</p>
    <p class="footer__meta">
      {t.builtWith} <a href="https://astro.build" target="_blank" rel="noopener noreferrer">Astro</a>
      &middot; {t.hostedOn} <a href="https://pages.github.com" target="_blank" rel="noopener noreferrer">GitHub Pages</a>
    </p>
    <p class="footer__links">
      <a href={t.blogHref} class="footer__link">{t.blog}</a>
      <span class="footer__sep" aria-hidden="true">&middot;</span>
      <a href="https://github.com/agent-engineering-studio" target="_blank" rel="noopener noreferrer" class="footer__link">{t.github}</a>
      <span class="footer__sep" aria-hidden="true">&middot;</span>
      <a href="#" class="footer__link">{t.privacy}</a>
    </p>
  </div>
</footer>

<style>
  .footer {
    padding: var(--space-2xl) 0;
    text-align: center;
    border-top: 1px solid var(--color-border);
  }

  .footer__logo {
    display: flex;
    justify-content: center;
    margin-bottom: var(--space-md);
  }

  .footer__logo-img {
    width: 80px;
    height: 80px;
    border-radius: 8px;
    opacity: 0.7;
    transition: opacity var(--transition-base);
  }

  .footer__logo-img:hover {
    opacity: 1;
  }

  .footer__copy {
    font-family: var(--font-heading);
    font-size: 0.85rem;
    color: var(--color-text-muted);
    margin-bottom: var(--space-xs);
  }

  .footer__meta {
    font-size: 0.8rem;
    color: var(--color-text-muted);
    margin-bottom: var(--space-sm);
  }

  .footer__meta a {
    color: var(--color-text-muted);
    text-decoration: underline;
    text-underline-offset: 2px;
  }

  .footer__meta a:hover {
    color: var(--color-accent);
  }

  .footer__links {
    font-size: 0.8rem;
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 0.5rem;
    flex-wrap: wrap;
  }

  .footer__sep {
    color: var(--color-border);
  }

  .footer__link {
    color: var(--color-text-muted);
    text-decoration: underline;
    text-underline-offset: 2px;
    transition: color var(--transition-fast);
  }

  .footer__link:hover {
    color: var(--color-accent);
  }

  .footer__link--support {
    color: var(--color-cta);
    font-weight: 600;
    text-decoration: none;
  }

  .footer__link--support:hover {
    color: var(--color-cta-hover);
  }
</style>
