---
/*
 * Footer.astro — Footer minimal
 * Per modificare i link o il testo: aggiorna l'HTML qui sotto.
 */
---

<footer class="footer">
  <div class="container">
    <p class="footer__copy">&copy; 2025–2026 Agent Engineering Studio</p>
    <p class="footer__meta">
      Built with <a href="https://astro.build" target="_blank" rel="noopener noreferrer">Astro</a>
      &middot; Hosted on <a href="https://pages.github.com" target="_blank" rel="noopener noreferrer">GitHub Pages</a>
    </p>
    <p class="footer__links">
      <a href="#" class="footer__link">Privacy Policy</a>
    </p>
  </div>
</footer>

<style>
  .footer {
    padding: var(--space-2xl) 0;
    text-align: center;
    border-top: 1px solid var(--color-border);
  }

  .footer__copy {
    font-family: var(--font-heading);
    font-size: 0.85rem;
    color: var(--color-text-muted);
    margin-bottom: var(--space-xs);
  }

  .footer__meta {
    font-size: 0.8rem;
    color: var(--color-text-muted);
    margin-bottom: var(--space-sm);
  }

  .footer__meta a {
    color: var(--color-text-muted);
    text-decoration: underline;
    text-underline-offset: 2px;
  }

  .footer__meta a:hover {
    color: var(--color-accent);
  }

  .footer__links {
    font-size: 0.8rem;
  }

  .footer__link {
    color: var(--color-text-muted);
    text-decoration: underline;
    text-underline-offset: 2px;
  }

  .footer__link:hover {
    color: var(--color-accent);
  }
</style>
