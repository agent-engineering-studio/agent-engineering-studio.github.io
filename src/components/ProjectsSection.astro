---
/*
 * ProjectsSection.astro — Catalogo progetti multi-project
 * Griglia di card con dettagli per ciascun progetto.
 * Dati allineati alla repository knowledge-graph/ reale.
 */

const modules = [
  { name: 'knowledge-graph-api', desc: 'FastAPI backend — ingestion, RAG, graph', tech: 'Python · FastAPI · Pydantic v2' },
  { name: 'knowledge-graph-ui', desc: 'Next.js 15 web frontend', tech: 'Next.js 15 · React 19 · Tailwind CSS 4' },
  { name: 'knowledge-graph-mcp', desc: 'MCP server — espone le API come tool LLM', tech: 'Python · FastMCP · SSE transport' },
  { name: 'knowledge-graph-agents', desc: 'Multi-agent orchestration (LangGraph)', tech: 'Python · LangGraph · StateGraph' },
];

const agents = [
  { name: 'Orchestrator', role: 'Classifica intent, crea il piano — mai tool diretti' },
  { name: 'Ingestion', role: 'Health check, dedup, ingest documenti' },
  { name: 'Analyst', role: 'Vector search / graph traversal / hybrid (3 strategie)' },
  { name: 'Validator', role: '4 Cypher query, KGQualityReport con overall_health' },
  { name: 'KGC', role: 'Graph Completion — relazioni mancanti' },
  { name: 'Synthesis', role: 'RAG context + LLM, report Markdown' },
  { name: 'Monitor', role: 'Health check + quality check, alert summary' },
];

const projects = [
  {
    slug: 'knowledge-graph',
    title: 'Knowledge Graph',
    status: 'In Development',
    description:
      'Sistema completo con pipeline di ingestion, vector store, graph database, hybrid RAG, interfaccia web e orchestrazione multi-agent basata su LangGraph. Progetto companion del libro "Knowledge Graph: dalla Teoria alla Pratica".',
    stack: ['Neo4j 5.18', 'Redis Stack', 'Ollama', 'FastAPI', 'LangGraph', 'Next.js 15', 'FastMCP', 'Docker Compose'],
    models: ['Llama 3', 'Qwen 2.5:14b', 'nomic-embed-text'],
    color: '#2196F3',
    repoUrl: 'https://github.com/agent-engineering-studio/knowledge-graph',
    services: [
      { name: 'UI', url: 'localhost:3000', desc: 'Next.js frontend' },
      { name: 'API', url: 'localhost:8000', desc: 'FastAPI REST + Swagger' },
      { name: 'Agent API', url: 'localhost:8002', desc: 'Multi-Agent Orchestration' },
      { name: 'MCP Server', url: 'localhost:8080', desc: 'MCP tool layer (SSE)' },
      { name: 'Neo4j', url: 'localhost:7474', desc: 'Graph DB Browser' },
      { name: 'RedisInsight', url: 'localhost:8001', desc: 'Redis web UI' },
    ],
  },
];

const project = projects[0];
---

<section class="projects" id="projects" aria-labelledby="projects-heading">
  <div class="container">
    <div class="projects__header animate-in">
      <h2 id="projects-heading" class="projects__title">Progetti</h2>
      <p class="projects__subtitle">
        Proof-of-concept aperti su agenti AI, sistemi multi-agente e Graph-RAG
      </p>
    </div>

    <article class="project-card animate-in">
      <div class="project-card__header">
        <span class="project-card__status">{project.status}</span>
        <h3 class="project-card__title">
          <span class="project-card__accent">Knowledge Graph</span>
        </h3>
        <p class="project-card__desc">{project.description}</p>
      </div>

      {/* Architecture diagram — fedele al README */}
      <div class="project-card__arch" aria-label="Architettura Knowledge Graph">
        <h4 class="project-card__section-title">Architettura</h4>
        <div class="arch-diagram">
          <div class="arch-row">
            <div class="arch-node arch-node--client">Client / LLM Host</div>
          </div>
          <div class="arch-edges" aria-hidden="true">
            <span class="arch-edge"></span>
            <span class="arch-edge"></span>
          </div>
          <div class="arch-row">
            <div class="arch-node arch-node--service">
              <span class="arch-node__name">MCP Server</span>
              <span class="arch-node__port">:8080</span>
            </div>
            <div class="arch-node arch-node--service">
              <span class="arch-node__name">Agent API</span>
              <span class="arch-node__port">:8002</span>
            </div>
          </div>
          <div class="arch-edges" aria-hidden="true">
            <span class="arch-edge"></span>
          </div>
          <div class="arch-row">
            <div class="arch-node arch-node--core">
              <span class="arch-node__name">FastAPI</span>
              <span class="arch-node__port">:8000</span>
            </div>
          </div>
          <div class="arch-edges" aria-hidden="true">
            <span class="arch-edge"></span>
            <span class="arch-edge"></span>
            <span class="arch-edge"></span>
          </div>
          <div class="arch-row">
            <div class="arch-node arch-node--infra">Neo4j :7474</div>
            <div class="arch-node arch-node--infra">Redis :6379</div>
            <div class="arch-node arch-node--infra">Ollama :11434</div>
          </div>
          <div class="arch-edges" aria-hidden="true">
            <span class="arch-edge"></span>
          </div>
          <div class="arch-row">
            <div class="arch-node arch-node--ui">
              <span class="arch-node__name">Next.js UI</span>
              <span class="arch-node__port">:3000</span>
            </div>
          </div>
        </div>
      </div>

      {/* Modules — 4 moduli reali del repo */}
      <div class="project-card__modules">
        <h4 class="project-card__section-title">Moduli</h4>
        <div class="modules-grid">
          {modules.map((mod) => (
            <div class="module-card">
              <span class="module-card__name">{mod.name}</span>
              <span class="module-card__desc">{mod.desc}</span>
              <span class="module-card__tech">{mod.tech}</span>
            </div>
          ))}
        </div>
      </div>

      {/* Agents — Supervisor + Specialists */}
      <div class="project-card__agents">
        <h4 class="project-card__section-title">Multi-Agent System (Supervisor + Specialists)</h4>
        <div class="agents-grid">
          {agents.map((agent, i) => (
            <div class={`agent-card ${i === 0 ? 'agent-card--orchestrator' : ''}`}>
              <span class="agent-card__name">{agent.name}</span>
              <span class="agent-card__role">{agent.role}</span>
            </div>
          ))}
        </div>
      </div>

      {/* Data Pipelines */}
      <div class="project-card__pipelines">
        <h4 class="project-card__section-title">Pipeline</h4>
        <div class="pipelines-grid">
          <div class="pipeline-card">
            <span class="pipeline-card__label">Ingestion</span>
            <span class="pipeline-card__flow">Document → Chunking → Embedding → Dedup → Entity Extraction → Redis + Neo4j</span>
          </div>
          <div class="pipeline-card">
            <span class="pipeline-card__label">RAG Query</span>
            <span class="pipeline-card__flow">Question → Intent Classification → Vector Search → Graph Traversal → LLM Generation</span>
          </div>
          <div class="pipeline-card">
            <span class="pipeline-card__label">Multi-Agent</span>
            <span class="pipeline-card__flow">Request → Orchestrator (LangGraph) → Specialist Agent → HTTP Tools → Response</span>
          </div>
        </div>
      </div>

      {/* Stack + Models */}
      <div class="project-card__stack">
        <h4 class="project-card__section-title">Stack</h4>
        <div class="stack-tags">
          {project.stack.map((tech) => (
            <span class="stack-tag">{tech}</span>
          ))}
        </div>
      </div>

      <div class="project-card__stack">
        <h4 class="project-card__section-title">Modelli LLM</h4>
        <div class="stack-tags">
          {project.models.map((model) => (
            <span class="stack-tag stack-tag--model">{model}</span>
          ))}
        </div>
      </div>

      {/* Services table */}
      <div class="project-card__services">
        <h4 class="project-card__section-title">Servizi Docker Compose</h4>
        <div class="services-grid">
          {project.services.map((svc) => (
            <div class="service-row">
              <span class="service-row__name">{svc.name}</span>
              <code class="service-row__url">{svc.url}</code>
              <span class="service-row__desc">{svc.desc}</span>
            </div>
          ))}
        </div>
      </div>

      {/* Repo link */}
      <div class="project-card__actions">
        <a href={project.repoUrl} target="_blank" rel="noopener noreferrer" class="project-card__repo-link">
          <svg width="16" height="16" viewBox="0 0 16 16" fill="currentColor" aria-hidden="true">
            <path d="M8 0C3.58 0 0 3.58 0 8c0 3.54 2.29 6.53 5.47 7.59.4.07.55-.17.55-.38 0-.19-.01-.82-.01-1.49-2.01.37-2.53-.49-2.69-.94-.09-.23-.48-.94-.82-1.13-.28-.15-.68-.52-.01-.53.63-.01 1.08.58 1.23.82.72 1.21 1.87.87 2.33.66.07-.52.28-.87.51-1.07-1.78-.2-3.64-.89-3.64-3.95 0-.87.31-1.59.82-2.15-.08-.2-.36-1.02.08-2.12 0 0 .67-.21 2.2.82.64-.18 1.32-.27 2-.27.68 0 1.36.09 2 .27 1.53-1.04 2.2-.82 2.2-.82.44 1.1.16 1.92.08 2.12.51.56.82 1.27.82 2.15 0 3.07-1.87 3.75-3.65 3.95.29.25.54.73.54 1.48 0 1.07-.01 1.93-.01 2.2 0 .21.15.46.55.38A8.013 8.013 0 0016 8c0-4.42-3.58-8-8-8z"/>
          </svg>
          Vai alla Repository
        </a>
      </div>
    </article>
  </div>
</section>

<style>
  .projects {
    padding: var(--space-3xl) 0;
    border-top: 1px solid var(--color-border);
  }

  .projects__header {
    text-align: center;
    margin-bottom: var(--space-2xl);
  }

  .projects__title {
    font-family: var(--font-heading);
    font-size: 0.85rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    color: var(--color-accent);
    margin-bottom: var(--space-sm);
  }

  .projects__subtitle {
    font-size: 0.95rem;
    color: var(--color-text-muted);
  }

  /* ── Project Card ── */
  .project-card {
    background: var(--color-bg-card);
    border: 1px solid var(--color-border);
    border-radius: var(--border-radius-lg);
    overflow: hidden;
    max-width: 900px;
    margin: 0 auto;
    padding: var(--space-xl);
    display: flex;
    flex-direction: column;
    gap: var(--space-xl);
  }

  .project-card__header {
    text-align: center;
  }

  .project-card__status {
    display: inline-block;
    padding: 0.2em 0.8em;
    font-family: var(--font-heading);
    font-size: 0.75rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    color: var(--color-bg);
    background: var(--color-accent);
    border-radius: 999px;
    margin-bottom: var(--space-md);
  }

  .project-card__title {
    font-family: var(--font-heading);
    font-size: clamp(1.4rem, 4vw, 2.2rem);
    font-weight: 700;
    color: var(--color-text);
    line-height: 1.2;
    margin-bottom: var(--space-sm);
  }

  .project-card__accent {
    color: var(--color-accent);
  }

  .project-card__desc {
    font-size: clamp(0.9rem, 2vw, 1rem);
    color: var(--color-text-muted);
    max-width: 680px;
    margin: 0 auto;
    line-height: 1.6;
  }

  .project-card__section-title {
    font-family: var(--font-heading);
    font-size: 0.8rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    color: var(--color-accent);
    text-align: center;
    margin-bottom: var(--space-md);
  }

  /* ── Architecture diagram ── */
  .arch-diagram {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: var(--space-xs);
    max-width: 600px;
    margin: 0 auto;
  }

  .arch-row {
    display: flex;
    gap: var(--space-sm);
    flex-wrap: wrap;
    justify-content: center;
  }

  .arch-node {
    font-family: var(--font-heading);
    font-size: 0.78rem;
    font-weight: 600;
    border-radius: var(--border-radius-lg);
    text-align: center;
    padding: var(--space-sm) var(--space-md);
  }

  .arch-node__name {
    display: block;
    font-weight: 700;
  }

  .arch-node__port {
    display: block;
    font-size: 0.65rem;
    font-weight: 400;
    opacity: 0.7;
  }

  .arch-node--client {
    background: rgba(33, 150, 243, 0.08);
    border: 1px dashed rgba(33, 150, 243, 0.3);
    color: var(--color-accent);
    padding: var(--space-sm) var(--space-xl);
  }

  .arch-node--service {
    background: var(--color-bg-card);
    border: 1px solid var(--color-border);
    color: var(--color-text);
    min-width: 130px;
  }

  .arch-node--core {
    background: var(--color-accent);
    color: var(--color-bg);
    min-width: 160px;
    padding: var(--space-md) var(--space-xl);
    font-size: 0.85rem;
  }

  .arch-node--core .arch-node__port {
    color: var(--color-bg);
  }

  .arch-node--infra {
    background: transparent;
    border: 1px solid var(--color-border);
    color: var(--color-text-muted);
    font-size: 0.72rem;
    min-width: 110px;
  }

  .arch-node--ui {
    background: var(--color-bg-card);
    border: 1px solid var(--color-border);
    color: var(--color-text);
  }

  .arch-edges {
    display: flex;
    justify-content: center;
    gap: var(--space-xl);
  }

  .arch-edge {
    display: block;
    width: 1px;
    height: 14px;
    background: var(--color-border);
  }

  /* ── Modules grid ── */
  .modules-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(200px, 1fr));
    gap: var(--space-sm);
    max-width: 860px;
    margin: 0 auto;
  }

  .module-card {
    background: rgba(33, 150, 243, 0.03);
    border: 1px solid var(--color-border);
    border-radius: var(--border-radius-lg);
    padding: var(--space-md);
    display: flex;
    flex-direction: column;
    gap: 0.25rem;
    transition: border-color var(--transition-base);
  }

  .module-card:hover {
    border-color: rgba(33, 150, 243, 0.3);
  }

  .module-card__name {
    font-family: var(--font-heading);
    font-size: 0.8rem;
    font-weight: 700;
    color: var(--color-text);
    word-break: break-all;
  }

  .module-card__desc {
    font-size: 0.78rem;
    color: var(--color-text-muted);
    line-height: 1.4;
  }

  .module-card__tech {
    font-family: var(--font-heading);
    font-size: 0.65rem;
    color: var(--color-accent);
    margin-top: auto;
  }

  /* ── Agents grid ── */
  .agents-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(180px, 1fr));
    gap: var(--space-sm);
    max-width: 860px;
    margin: 0 auto;
  }

  .agent-card {
    background: rgba(33, 150, 243, 0.04);
    border: 1px solid var(--color-border);
    border-radius: var(--border-radius-lg);
    padding: var(--space-sm) var(--space-md);
    text-align: center;
    transition: border-color var(--transition-base), box-shadow var(--transition-base);
  }

  .agent-card:hover {
    border-color: rgba(33, 150, 243, 0.3);
    box-shadow: 0 0 12px var(--color-accent-glow);
  }

  .agent-card--orchestrator {
    border-color: var(--color-accent);
    background: rgba(33, 150, 243, 0.08);
    grid-column: 1 / -1;
  }

  .agent-card__name {
    display: block;
    font-family: var(--font-heading);
    font-size: 0.85rem;
    font-weight: 700;
    color: var(--color-text);
  }

  .agent-card__role {
    display: block;
    font-size: 0.72rem;
    color: var(--color-text-muted);
    line-height: 1.4;
    margin-top: 0.15em;
  }

  .agent-card--orchestrator .agent-card__name {
    color: var(--color-accent);
  }

  /* ── Pipelines ── */
  .pipelines-grid {
    display: flex;
    flex-direction: column;
    gap: var(--space-sm);
    max-width: 700px;
    margin: 0 auto;
  }

  .pipeline-card {
    background: rgba(33, 150, 243, 0.03);
    border: 1px solid var(--color-border);
    border-radius: var(--border-radius-lg);
    padding: var(--space-sm) var(--space-md);
    display: flex;
    gap: var(--space-md);
    align-items: baseline;
  }

  .pipeline-card__label {
    font-family: var(--font-heading);
    font-size: 0.75rem;
    font-weight: 700;
    color: var(--color-accent);
    text-transform: uppercase;
    letter-spacing: 0.05em;
    min-width: 90px;
    flex-shrink: 0;
  }

  .pipeline-card__flow {
    font-size: 0.8rem;
    color: var(--color-text-muted);
    line-height: 1.5;
  }

  /* ── Stack tags ── */
  .project-card__stack {
    text-align: center;
  }

  .stack-tags {
    display: flex;
    flex-wrap: wrap;
    justify-content: center;
    gap: var(--space-sm);
  }

  .stack-tag {
    padding: 0.3em 0.9em;
    font-family: var(--font-heading);
    font-size: 0.8rem;
    color: var(--color-text-muted);
    background: var(--color-bg-card);
    border: 1px solid var(--color-border);
    border-radius: 999px;
    transition: border-color var(--transition-base);
  }

  .stack-tag:hover {
    border-color: rgba(33, 150, 243, 0.3);
    color: var(--color-accent);
  }

  .stack-tag--model {
    border-color: rgba(255, 153, 0, 0.3);
    color: #ff9900;
  }

  .stack-tag--model:hover {
    border-color: rgba(255, 153, 0, 0.5);
  }

  /* ── Services grid ── */
  .services-grid {
    display: flex;
    flex-direction: column;
    gap: 0.4rem;
    max-width: 600px;
    margin: 0 auto;
  }

  .service-row {
    display: grid;
    grid-template-columns: 100px 140px 1fr;
    gap: var(--space-sm);
    align-items: center;
    padding: 0.4em 0.6em;
    border-radius: var(--border-radius);
    transition: background var(--transition-fast);
  }

  .service-row:hover {
    background: rgba(33, 150, 243, 0.04);
  }

  .service-row__name {
    font-family: var(--font-heading);
    font-size: 0.8rem;
    font-weight: 600;
    color: var(--color-text);
  }

  .service-row__url {
    font-size: 0.72rem;
    color: var(--color-accent);
  }

  .service-row__desc {
    font-size: 0.75rem;
    color: var(--color-text-muted);
  }

  /* ── Actions ── */
  .project-card__actions {
    text-align: center;
  }

  .project-card__repo-link {
    display: inline-flex;
    align-items: center;
    gap: 0.5em;
    font-family: var(--font-heading);
    font-size: 0.85rem;
    font-weight: 600;
    color: var(--color-text);
    text-decoration: none;
    padding: 0.6em 1.5em;
    border: 1px solid var(--color-border);
    border-radius: var(--border-radius-lg);
    transition: border-color var(--transition-base), color var(--transition-base), box-shadow var(--transition-base);
  }

  .project-card__repo-link:hover {
    border-color: var(--color-accent);
    color: var(--color-accent);
    box-shadow: 0 0 16px var(--color-accent-glow);
  }

  @media (max-width: 500px) {
    .modules-grid {
      grid-template-columns: 1fr;
    }
    .agents-grid {
      grid-template-columns: 1fr 1fr;
    }
    .service-row {
      grid-template-columns: 1fr;
      gap: 0.1rem;
    }
    .pipeline-card {
      flex-direction: column;
      gap: 0.3rem;
    }
  }
</style>
