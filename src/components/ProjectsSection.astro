---
/*
 * ProjectsSection.astro — Grid dei progetti open source
 * Mostra tutti i 4 repo attivi + osm-italia-mcp coming soon
 */

const projects = [
  {
    slug: 'mcp-ckan',
    icon: '📦',
    title: 'mcp-ckan',
    status: 'Open Source',
    statusClass: 'status--open',
    description:
      'MCP server per i portali open data basati su CKAN — dati.gov.it, portali regionali e comunali. Query in linguaggio naturale sui dataset della PA.',
    stack: ['Python', 'FastMCP', 'CKAN API', 'Ollama'],
    repoUrl: 'https://github.com/agent-engineering-studio/mcp-ckan',
  },
  {
    slug: 'mcp-istat',
    icon: '📊',
    title: 'mcp-istat',
    status: 'Open Source',
    statusClass: 'status--open',
    description:
      'MCP server per i dati statistici ISTAT via SDMX API. Popolazione, economia, lavoro e territorio interrogabili come tool MCP.',
    stack: ['Python', 'FastMCP', 'SDMX API', 'ISTAT'],
    repoUrl: 'https://github.com/agent-engineering-studio/mcp-istat',
  },
  {
    slug: 'mcp-osm',
    icon: '🗺️',
    title: 'mcp-osm',
    status: 'Open Source',
    statusClass: 'status--open',
    description:
      'MCP server per OpenStreetMap: Overpass API, Nominatim geocoding e OSRM routing. Interroga la mappa italiana in linguaggio naturale.',
    stack: ['Python', 'FastMCP', 'Overpass API', 'Nominatim', 'OSRM'],
    repoUrl: 'https://github.com/agent-engineering-studio/mcp-osm',
  },
  {
    slug: 'knowledge-graph',
    icon: '🧠',
    title: 'knowledge-graph',
    status: 'In Development',
    statusClass: 'status--dev',
    description:
      'Knowledge graph per connettere entità geografiche, statistiche e documentali. Backend multi-agente con LangGraph, Neo4j e FastMCP.',
    stack: ['Python', 'FastAPI', 'LangGraph', 'Neo4j', 'Redis', 'FastMCP', 'Next.js 15'],
    repoUrl: 'https://github.com/agent-engineering-studio/knowledge-graph',
  },
  {
    slug: 'osm-italia-mcp',
    icon: '🇮🇹',
    title: 'osm-italia-mcp',
    status: 'Coming Soon',
    statusClass: 'status--soon',
    description:
      'Il primo MCP server .NET per i dati geospaziali italiani: OSM, ISTAT, Catasto e RNDT in un unico server C# con Microsoft Agent Framework 1.0.',
    stack: ['.NET 9', 'C#', 'MAF 1.0', 'MCP SDK', 'Overpass', 'Nominatim', 'ISTAT', 'Catasto'],
    repoUrl: 'https://github.com/agent-engineering-studio',
  },
];
---

<section class="projects" aria-label="Progetti open source">
  <div class="container">
    <h2 class="projects__heading">Progetti</h2>
    <p class="projects__intro">
      Tutti i repository sono aperti e accettano contributi. Se usi questi strumenti o vuoi collaborare, apri una issue o una PR.
    </p>

    <div class="projects__grid">
      {projects.map((p) => (
        <article class={`project-card ${p.statusClass === 'status--soon' ? 'project-card--soon' : ''}`}>
          <div class="project-card__header">
            <span class="project-card__icon" aria-hidden="true">{p.icon}</span>
            <span class={`project-card__status ${p.statusClass}`}>{p.status}</span>
          </div>

          <h3 class="project-card__title">{p.title}</h3>
          <p class="project-card__desc">{p.description}</p>

          <div class="project-card__stack">
            {p.stack.map((tag) => (
              <span class="project-card__tag">{tag}</span>
            ))}
          </div>

          <a
            href={p.repoUrl}
            target="_blank"
            rel="noopener noreferrer"
            class="project-card__link"
            aria-label={`Vai al repository ${p.title} su GitHub`}
          >
            <svg width="14" height="14" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
              <path d="M12 0C5.374 0 0 5.373 0 12c0 5.302 3.438 9.8 8.207 11.387.599.111.793-.261.793-.577v-2.234c-3.338.726-4.033-1.416-4.033-1.416-.546-1.387-1.333-1.756-1.333-1.756-1.089-.745.083-.729.083-.729 1.205.084 1.839 1.237 1.839 1.237 1.07 1.834 2.807 1.304 3.492.997.107-.775.418-1.305.762-1.604-2.665-.305-5.467-1.334-5.467-5.931 0-1.311.469-2.381 1.236-3.221-.124-.303-.535-1.524.117-3.176 0 0 1.008-.322 3.301 1.23A11.509 11.509 0 0 1 12 5.803c1.02.005 2.047.138 3.006.404 2.291-1.552 3.297-1.23 3.297-1.23.653 1.653.242 2.874.118 3.176.77.84 1.235 1.911 1.235 3.221 0 4.609-2.807 5.624-5.479 5.921.43.372.823 1.102.823 2.222v3.293c0 .319.192.694.801.576C20.566 21.797 24 17.3 24 12c0-6.627-5.373-12-12-12z"/>
            </svg>
            {p.statusClass === 'status--soon' ? 'Org GitHub' : 'Vai al repo'}
          </a>
        </article>
      ))}
    </div>
  </div>
</section>

<style>
  .projects {
    padding: var(--space-xl) 0;
  }

  .projects__heading {
    text-align: center;
    font-size: 1.4rem;
    font-weight: 700;
    color: var(--color-text);
    margin-bottom: var(--space-sm);
  }

  .projects__intro {
    text-align: center;
    font-size: 0.9rem;
    color: var(--color-text-muted);
    margin-bottom: var(--space-xl);
    max-width: 520px;
    margin-left: auto;
    margin-right: auto;
    line-height: 1.6;
  }

  .projects__grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(280px, 1fr));
    gap: var(--space-md);
  }

  .project-card {
    display: flex;
    flex-direction: column;
    padding: var(--space-lg);
    background: rgba(15, 34, 64, 0.4);
    border: 1px solid var(--color-border);
    border-radius: var(--border-radius-lg, 12px);
    transition: border-color 0.2s, transform 0.2s;
  }

  .project-card:hover {
    border-color: var(--color-accent);
    transform: translateY(-2px);
  }

  .project-card--soon {
    opacity: 0.75;
    border-style: dashed;
  }

  .project-card--soon:hover {
    opacity: 0.9;
  }

  .project-card__header {
    display: flex;
    align-items: center;
    justify-content: space-between;
    margin-bottom: var(--space-sm);
  }

  .project-card__icon {
    font-size: 1.5rem;
  }

  .project-card__status {
    font-size: 0.72rem;
    font-weight: 700;
    padding: 0.2rem 0.6rem;
    border-radius: 999px;
    letter-spacing: 0.03em;
    text-transform: uppercase;
  }

  .status--open {
    background: rgba(52, 211, 153, 0.15);
    color: #34d399;
    border: 1px solid rgba(52, 211, 153, 0.3);
  }

  .status--dev {
    background: rgba(251, 191, 36, 0.15);
    color: #fbbf24;
    border: 1px solid rgba(251, 191, 36, 0.3);
  }

  .status--soon {
    background: rgba(148, 163, 184, 0.1);
    color: var(--color-text-muted);
    border: 1px solid rgba(148, 163, 184, 0.2);
  }

  .project-card__title {
    font-size: 1rem;
    font-weight: 700;
    color: var(--color-text);
    margin-bottom: var(--space-xs);
    font-family: var(--font-mono, monospace);
  }

  .project-card__desc {
    font-size: 0.86rem;
    color: var(--color-text-muted);
    line-height: 1.6;
    flex: 1;
    margin-bottom: var(--space-md);
  }

  .project-card__stack {
    display: flex;
    flex-wrap: wrap;
    gap: 0.3rem;
    margin-bottom: var(--space-md);
  }

  .project-card__tag {
    font-size: 0.72rem;
    padding: 0.15rem 0.5rem;
    background: rgba(255, 255, 255, 0.05);
    border: 1px solid rgba(255, 255, 255, 0.08);
    border-radius: 4px;
    color: var(--color-text-muted);
    font-family: var(--font-mono, monospace);
  }

  .project-card__link {
    display: inline-flex;
    align-items: center;
    gap: 0.4rem;
    font-size: 0.82rem;
    font-weight: 600;
    color: var(--color-accent);
    text-decoration: none;
    border-bottom: 1px solid transparent;
    transition: border-color 0.2s, color 0.2s;
    width: fit-content;
  }

  .project-card__link:hover {
    color: var(--color-cta);
    border-bottom-color: var(--color-cta);
  }
</style>
