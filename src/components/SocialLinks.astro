---
/*
 * SocialLinks.astro — Link GitHub org + social + newsletter
 * Per aggiungere altri social: aggiungere elementi alla lista qui sotto.
 * Icone SVG inline, nessuna dipendenza esterna.
 */
---

<nav class="social-links animate-in animate-delay-7" aria-label="Social links">
  <div class="container">
    <ul class="social-links__list">
      <!-- GitHub -->
      <li>
        <a
          href="https://github.com/agent-engineering-studio"
          target="_blank"
          rel="noopener noreferrer"
          class="social-links__link"
          aria-label="GitHub - Agent Engineering Studio"
        >
          <svg width="24" height="24" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
            <path d="M12 0C5.374 0 0 5.373 0 12c0 5.302 3.438 9.8 8.207 11.387.599.111.793-.261.793-.577v-2.234c-3.338.726-4.033-1.416-4.033-1.416-.546-1.387-1.333-1.756-1.333-1.756-1.089-.745.083-.729.083-.729 1.205.084 1.839 1.237 1.839 1.237 1.07 1.834 2.807 1.304 3.492.997.107-.775.418-1.305.762-1.604-2.665-.305-5.467-1.334-5.467-5.931 0-1.311.469-2.381 1.236-3.221-.124-.303-.535-1.524.117-3.176 0 0 1.008-.322 3.301 1.23A11.509 11.509 0 0 1 12 5.803c1.02.005 2.047.138 3.006.404 2.291-1.552 3.297-1.23 3.297-1.23.653 1.653.242 2.874.118 3.176.77.84 1.235 1.911 1.235 3.221 0 4.609-2.807 5.624-5.479 5.921.43.372.823 1.102.823 2.222v3.293c0 .319.192.694.801.576C20.566 21.797 24 17.3 24 12c0-6.627-5.373-12-12-12z"/>
          </svg>
          <span>Agent Engineering Studio</span>
        </a>
      </li>

      <!-- LinkedIn -->
      <li>
        <a
          href="https://www.linkedin.com/in/giuseppezileni/"
          target="_blank"
          rel="noopener noreferrer"
          class="social-links__link"
          aria-label="LinkedIn - Giuseppe Zileni"
        >
          <svg width="24" height="24" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
            <path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433a2.062 2.062 0 0 1-2.063-2.065 2.064 2.064 0 1 1 2.063 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z"/>
          </svg>
          <span>Giuseppe Zileni</span>
        </a>
      </li>

      <!-- Medium -->
      <li>
        <a
          href="https://medium.com/@giuseppezileni"
          target="_blank"
          rel="noopener noreferrer"
          class="social-links__link"
          aria-label="Medium - Giuseppe Zileni"
        >
          <svg width="24" height="24" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
            <path d="M13.54 12a6.8 6.8 0 0 1-6.77 6.82A6.8 6.8 0 0 1 0 12a6.8 6.8 0 0 1 6.77-6.82A6.8 6.8 0 0 1 13.54 12zM20.96 12c0 3.54-1.51 6.42-3.38 6.42-1.87 0-3.39-2.88-3.39-6.42s1.52-6.42 3.39-6.42 3.38 2.88 3.38 6.42M24 12c0 3.17-.53 5.75-1.19 5.75-.66 0-1.19-2.58-1.19-5.75s.53-5.75 1.19-5.75C23.47 6.25 24 8.83 24 12z"/>
          </svg>
          <span>Blog</span>
        </a>
      </li>

      <!-- LinkedIn Newsletter -->
      <li>
        <a
          href="https://www.linkedin.com/build-relation/newsletter-follow?entityUrn=7445502996655800320"
          target="_blank"
          rel="noopener noreferrer"
          class="social-links__link social-links__link--newsletter"
          aria-label="Iscriviti alla Newsletter LinkedIn"
        >
          <svg width="24" height="24" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
            <path d="M20 4H4c-1.1 0-2 .9-2 2v12c0 1.1.9 2 2 2h16c1.1 0 2-.9 2-2V6c0-1.1-.9-2-2-2zm0 4-8 5-8-5V6l8 5 8-5v2z"/>
          </svg>
          <span>Iscriviti alla Newsletter</span>
        </a>
      </li>
    </ul>
  </div>
</nav>

<style>
  .social-links {
    padding: var(--space-xl) 0;
    text-align: center;
  }

  .social-links__list {
    display: flex;
    justify-content: center;
    flex-wrap: wrap;
    gap: var(--space-lg);
  }

  .social-links__link {
    display: inline-flex;
    align-items: center;
    gap: var(--space-sm);
    padding: var(--space-sm) var(--space-md);
    color: var(--color-text-muted);
    border: 1px solid var(--color-border);
    border-radius: var(--border-radius);
    transition:
      color var(--transition-fast),
      border-color var(--transition-fast),
      background var(--transition-fast);
    font-size: 0.9rem;
  }

  .social-links__link:hover {
    color: var(--color-accent);
    border-color: rgba(0, 229, 255, 0.3);
    background: var(--color-accent-glow);
  }

  .social-links__link svg {
    width: 20px;
    height: 20px;
  }

  /* Newsletter button — LinkedIn blue style */
  .social-links__link--newsletter {
    color: #ffffff;
    background-color: #0A66C2;
    border-color: #0A66C2;
    border-radius: 16px;
    font-weight: 600;
  }

  .social-links__link--newsletter:hover {
    color: #ffffff;
    background-color: #004182;
    border-color: #004182;
  }

  @media (max-width: 500px) {
    .social-links__list {
      flex-direction: column;
      align-items: center;
      gap: var(--space-md);
    }
  }
</style>
