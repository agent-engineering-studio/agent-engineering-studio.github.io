---
/*
 * Navbar.astro — Barra di navigazione sticky in cima al sito
 * Supporta lang: 'it' | 'en' per label e switcher di lingua.
 */
import FlagIcon from './FlagIcon.astro';

interface Props {
  lang?: 'it' | 'en';
  /** URL della controparte nell'altra lingua. Se assente, lo switcher non viene mostrato. */
  altLangHref?: string;
}

const { lang = 'it', altLangHref } = Astro.props;

const t = {
  it: {
    home: 'Agent Engineering Studio — torna alla home',
    blog: 'Newsletter',
    projects: 'Progetti',
    github: 'GitHub',
    githubAria: 'Agent Engineering Studio su GitHub (apre in nuova scheda)',
    blogAria: 'Newsletter Substack (apre in nuova scheda)',
    nav: 'Navigazione principale',
    switchAria: 'Read in English',
    switchTitle: 'Read in English',
    switchCountry: 'gb' as const,
  },
  en: {
    home: 'Agent Engineering Studio — back to home',
    blog: 'Newsletter',
    projects: 'Projects',
    github: 'GitHub',
    githubAria: 'Agent Engineering Studio on GitHub (opens in a new tab)',
    blogAria: 'Substack Newsletter (opens in a new tab)',
    nav: 'Main navigation',
    switchAria: 'Leggi in italiano',
    switchTitle: 'Leggi in italiano',
    switchCountry: 'it' as const,
  },
}[lang];

const blogHref = 'https://gzileni.substack.com';
const projectsHref = lang === 'en' ? '/en/#projects' : '/#progetti';
---

<nav class="navbar" role="navigation" aria-label={t.nav}>
  <div class="navbar__inner">

    <!-- Logo / home link -->
    <a href={lang === 'en' ? '/en/' : '/'} class="navbar__brand" aria-label={t.home}>
      <img
        src="/logo-horizontal.png"
        alt="Agent Engineering Studio"
        class="navbar__logo"
        width="235"
        height="56"
      />
    </a>

    <!-- Links -->
    <ul class="navbar__links" role="list">

      <li>
        <a
          href={blogHref}
          target="_blank"
          rel="noopener noreferrer"
          class="navbar__link"
          aria-label={t.blogAria}
        >
          <!-- Newsletter / mail icon -->
          <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor"
               stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
            <path d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z"/>
            <polyline points="22,6 12,13 2,6"/>
          </svg>
          {t.blog}
        </a>
      </li>

      <li>
        <a href={projectsHref} class="navbar__link">
          <!-- Grid icon -->
          <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor"
               stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
            <rect x="3" y="3" width="7" height="7"/>
            <rect x="14" y="3" width="7" height="7"/>
            <rect x="3" y="14" width="7" height="7"/>
            <rect x="14" y="14" width="7" height="7"/>
          </svg>
          {t.projects}
        </a>
      </li>

      <li>
        <a
          href="https://github.com/agent-engineering-studio"
          target="_blank"
          rel="noopener noreferrer"
          class="navbar__link navbar__link--github"
          aria-label={t.githubAria}
        >
          <!-- GitHub icon -->
          <svg width="16" height="16" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
            <path d="M12 0C5.374 0 0 5.373 0 12c0 5.302 3.438 9.8 8.207 11.387.599.111.793-.261.793-.577v-2.234c-3.338.726-4.033-1.416-4.033-1.416-.546-1.387-1.333-1.756-1.333-1.756-1.089-.745.083-.729.083-.729 1.205.084 1.839 1.237 1.839 1.237 1.07 1.834 2.807 1.304 3.492.997.107-.775.418-1.305.762-1.604-2.665-.305-5.467-1.334-5.467-5.931 0-1.311.469-2.381 1.236-3.221-.124-.303-.535-1.524.117-3.176 0 0 1.008-.322 3.301 1.23A11.509 11.509 0 0 1 12 5.803c1.02.005 2.047.138 3.006.404 2.291-1.552 3.297-1.23 3.297-1.23.653 1.653.242 2.874.118 3.176.77.84 1.235 1.911 1.235 3.221 0 4.609-2.807 5.624-5.479 5.921.43.372.823 1.102.823 2.222v3.293c0 .319.192.694.801.576C20.566 21.797 24 17.3 24 12c0-6.627-5.373-12-12-12z"/>
          </svg>
          {t.github}
        </a>
      </li>

      {altLangHref && (
        <li>
          <a
            href={altLangHref}
            class="navbar__lang-switch"
            hreflang={lang === 'it' ? 'en' : 'it'}
            lang={lang === 'it' ? 'en' : 'it'}
            aria-label={t.switchAria}
            title={t.switchTitle}
          >
            <FlagIcon country={t.switchCountry} />
          </a>
        </li>
      )}

    </ul>
  </div>
</nav>

<style>
  .navbar {
    position: sticky;
    top: 0;
    z-index: 100;
    background: rgba(10, 14, 23, 0.85);
    backdrop-filter: blur(12px);
    -webkit-backdrop-filter: blur(12px);
    border-bottom: 1px solid var(--color-border);
  }

  .navbar__inner {
    max-width: 1100px;
    margin: 0 auto;
    padding: 0 var(--space-lg);
    height: 80px;
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: var(--space-lg);
  }

  .navbar__brand {
    display: flex;
    align-items: center;
    text-decoration: none;
    flex-shrink: 0;
  }

  .navbar__logo {
    height: 56px;
    width: auto;
    display: block;
  }

  .navbar__links {
    display: flex;
    align-items: center;
    gap: 0.25rem;
    list-style: none;
    margin: 0;
    padding: 0;
  }

  .navbar__link {
    display: inline-flex;
    align-items: center;
    gap: 0.35rem;
    padding: 0.4rem 0.75rem;
    border-radius: 6px;
    font-size: 0.87rem;
    font-weight: 500;
    color: var(--color-text-muted);
    text-decoration: none;
    transition: color 0.18s, background 0.18s;
    white-space: nowrap;
  }

  .navbar__link:hover {
    color: var(--color-text);
    background: rgba(255, 255, 255, 0.07);
  }

  .navbar__link--github {
    margin-left: 0.25rem;
    padding: 0.4rem 0.9rem;
    background: rgba(255, 255, 255, 0.06);
    border: 1px solid var(--color-border);
    color: var(--color-text);
    font-weight: 600;
  }

  .navbar__link--github:hover {
    background: rgba(255, 255, 255, 0.11);
    border-color: rgba(255, 255, 255, 0.2);
  }

  .navbar__lang-switch {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    margin-left: 0.5rem;
    padding: 0.35em 0.7em;
    border: 1px solid var(--color-border);
    border-radius: 999px;
    color: var(--color-text-muted);
    text-decoration: none;
    transition: color 0.18s, border-color 0.18s;
  }
  .navbar__lang-switch:hover {
    color: var(--color-accent);
    border-color: rgba(33, 150, 243, 0.4);
  }

  @media (max-width: 600px) {
    .navbar__inner {
      height: 64px;
    }
    .navbar__logo {
      height: 40px;
    }
  }

  @media (max-width: 420px) {
    .navbar__link span,
    .navbar__link svg + * {
      display: none;
    }

    .navbar__link {
      padding: 0.4rem 0.55rem;
    }
  }
</style>
