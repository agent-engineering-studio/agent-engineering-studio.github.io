---
/*
 * Pillars.astro — I 4 ambiti del laboratorio
 */
interface Props {
  lang?: 'it' | 'en';
}
const { lang = 'it' } = Astro.props;

const copy = {
  it: {
    heading: 'Cosa faccio qui',
    pillars: [
      {
        icon: '📖',
        title: 'Studio',
        description:
          'Approfondimenti su agenti AI, Knowledge Graph, retrieval ibrido e protocolli emergenti. Quello che imparo lo scrivo, quello che scrivo lo pubblico.',
      },
      {
        icon: '🧪',
        title: 'Sperimentazione',
        description:
          'Prototipi open source per testare architetture, pattern e idee. Codice eseguibile, non solo teoria.',
      },
      {
        icon: '📚',
        title: 'Divulgazione',
        description:
          'Libri tecnici in italiano, articoli e tutorial per rendere accessibili tecniche enterprise anche a chi studia da solo.',
      },
      {
        icon: '🌱',
        title: 'Community',
        description:
          'Uno spazio aperto: chi vuole leggere, discutere o contribuire è benvenuto. Senza ruoli, senza adesioni.',
      },
    ],
  },
  en: {
    heading: 'What I do here',
    pillars: [
      {
        icon: '📖',
        title: 'Study',
        description:
          'Deep dives on AI agents, Knowledge Graphs, hybrid retrieval and emerging protocols. What I learn I write down, what I write down I publish.',
      },
      {
        icon: '🧪',
        title: 'Experimentation',
        description:
          'Open source prototypes to test architectures, patterns and ideas. Runnable code, not just theory.',
      },
      {
        icon: '📚',
        title: 'Dissemination',
        description:
          'Technical books, articles and tutorials that make enterprise-grade techniques accessible to self-taught learners.',
      },
      {
        icon: '🌱',
        title: 'Community',
        description:
          'An open space: anyone who wants to read, discuss or contribute is welcome. No roles, no memberships.',
      },
    ],
  },
}[lang];
---

<section class="pillars" aria-label={lang === 'en' ? 'Areas of the lab' : 'Ambiti del laboratorio'}>
  <div class="container">
    <h2 class="pillars__heading">{copy.heading}</h2>
    <div class="pillars__grid">
      {copy.pillars.map((pillar) => (
        <div class="pillar">
          <div class="pillar__icon" aria-hidden="true">{pillar.icon}</div>
          <h3 class="pillar__title">{pillar.title}</h3>
          <p class="pillar__desc">{pillar.description}</p>
        </div>
      ))}
    </div>
  </div>
</section>

<style>
  .pillars {
    padding: var(--space-xl) 0;
  }

  .pillars__heading {
    text-align: center;
    font-size: 1.4rem;
    font-weight: 700;
    color: var(--color-text);
    margin-bottom: var(--space-xl);
  }

  .pillars__grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(240px, 1fr));
    gap: var(--space-lg);
  }

  .pillar {
    padding: var(--space-lg);
    background: rgba(15, 34, 64, 0.4);
    border: 1px solid var(--color-border);
    border-radius: var(--border-radius-lg, 12px);
    transition: border-color 0.2s, transform 0.2s;
  }

  .pillar:hover {
    border-color: var(--color-accent);
    transform: translateY(-2px);
  }

  .pillar__icon {
    font-size: 1.8rem;
    margin-bottom: var(--space-sm);
  }

  .pillar__title {
    font-size: 1rem;
    font-weight: 700;
    color: var(--color-text);
    margin-bottom: var(--space-xs);
  }

  .pillar__desc {
    font-size: 0.88rem;
    color: var(--color-text-muted);
    line-height: 1.65;
  }
</style>
