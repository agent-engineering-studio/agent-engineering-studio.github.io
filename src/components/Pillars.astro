---
/*
 * Pillars.astro — I 4 pilastri del laboratorio
 * Aggiornato per direzione Wikimedia Italia / MCP open data italiani
 */

const pillars = [
  {
    icon: '🗺️',
    title: "MCP server per l'Italia",
    description:
      'Server open-source che espongono OpenStreetMap, ISTAT, CKAN e i dataset PA come tool MCP — interrogabili in linguaggio naturale da qualsiasi agente AI compatibile.',
  },
  {
    icon: '🤝',
    title: 'Community & collaborazioni',
    description:
      'Vogliamo crescere dentro la community Wikimedia Italia e OpenStreetMap Italia, trovare co-contributori e costruire ponti tra civic tech, PA e volontariato digitale.',
  },
  {
    icon: '📚',
    title: 'Formazione in italiano',
    description:
      'Tutorial, guide e articoli sul protocollo MCP e gli agenti AI scritti in italiano — per rendere questi strumenti accessibili a sviluppatori, ricercatori e appassionati.',
  },
  {
    icon: '🏛️',
    title: 'Civic tech',
    description:
      'Agenti AI per la trasparenza e il bene comune: appalti pubblici, accessibilità urbana, dati catastali, emergenze e patrimonio culturale aperto.',
  },
];
---

<section class="pillars" aria-label="Pilastri del laboratorio">
  <div class="container">
    <h2 class="pillars__heading">Cosa costruiamo</h2>
    <div class="pillars__grid">
      {pillars.map((pillar) => (
        <div class="pillar">
          <div class="pillar__icon" aria-hidden="true">{pillar.icon}</div>
          <h3 class="pillar__title">{pillar.title}</h3>
          <p class="pillar__desc">{pillar.description}</p>
        </div>
      ))}
    </div>
  </div>
</section>

<style>
  .pillars {
    padding: var(--space-xl) 0;
  }

  .pillars__heading {
    text-align: center;
    font-size: 1.4rem;
    font-weight: 700;
    color: var(--color-text);
    margin-bottom: var(--space-xl);
  }

  .pillars__grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(240px, 1fr));
    gap: var(--space-lg);
  }

  .pillar {
    padding: var(--space-lg);
    background: rgba(15, 34, 64, 0.4);
    border: 1px solid var(--color-border);
    border-radius: var(--border-radius-lg, 12px);
    transition: border-color 0.2s, transform 0.2s;
  }

  .pillar:hover {
    border-color: var(--color-accent);
    transform: translateY(-2px);
  }

  .pillar__icon {
    font-size: 1.8rem;
    margin-bottom: var(--space-sm);
  }

  .pillar__title {
    font-size: 1rem;
    font-weight: 700;
    color: var(--color-text);
    margin-bottom: var(--space-xs);
  }

  .pillar__desc {
    font-size: 0.88rem;
    color: var(--color-text-muted);
    line-height: 1.65;
  }
</style>
