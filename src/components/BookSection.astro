---
/*
 * BookSection.astro — Sezione dedicata al libro "Knowledge Graph: dalla Teoria alla Pratica"
 * Presenta il libro con descrizione, indice delle parti, stack tecnologico,
 * pulsante acquisto Amazon e badge "Disponibile su Amazon" (conforme linee guida KDP).
 *
 * NOTA: Aggiornare AMAZON_BOOK_URL quando il libro sarà pubblicato su Amazon.
 */

/* ─── Amazon Book URL ─── */
/* Sostituire con l'URL reale della pagina Amazon del libro una volta pubblicato */
const AMAZON_BOOK_URL = '#'; // TODO: inserire URL Amazon reale

const parts = [
  {
    number: '1',
    title: 'Fondamenti',
    chapters: '1–4',
    desc: 'Teoria dei KG, modelli dati, query, ontologie',
  },
  {
    number: '2',
    title: 'Costruire con Python',
    chapters: '5–9',
    desc: 'Architettura, ingestion, entity extraction, Cypher',
  },
  {
    number: '3',
    title: 'RAG e LLM',
    chapters: '10–12',
    desc: 'Vector store, pipeline RAG, interfacce NL',
  },
  {
    number: '4',
    title: 'Avanzato e Produzione',
    chapters: '13–16',
    desc: 'KG Completion, deployment, pipeline da testo, metriche qualità',
  },
  {
    number: '5',
    title: 'MCP e Agenti',
    chapters: '17–23',
    desc: 'Model Context Protocol, Agent Framework, orchestrazione multi-agente',
  },
];

const stack = ['Python 3.11+', 'C# (.NET 9)', 'Neo4j', 'Redis for AI', 'Ollama', 'FastAPI', 'Docker', 'MCP', 'Agent Framework'];

const formats = [
  { label: 'Paperback', detail: '7" × 10" — Full color', icon: '📖' },
  { label: 'eBook Kindle', detail: 'EPUB 3.0 — Reflowable', icon: '📱' },
];
---

<section class="book" id="book" aria-labelledby="book-heading">
  <div class="container">

    <div class="book__header animate-in">
      <span class="book__badge">Nuovo — 2ª Edizione</span>
      <h2 id="book-heading" class="book__title">
        Knowledge Graph: dalla Teoria alla Pratica
      </h2>
      <p class="book__subtitle">
        Un percorso completo dalla teoria accademica all'implementazione enterprise
        con Python, MCP e Agent Framework
      </p>
      <p class="book__meta">
        Giuseppe Zileni &mdash; v2.0, Marzo 2026 &mdash; 23 capitoli + 4 appendici &mdash; 189 pagine a colori
      </p>
    </div>

    <div class="book__content">

      <!-- Amazon CTA -->
      <div class="book__cta animate-in">
        <a
          href={AMAZON_BOOK_URL}
          target="_blank"
          rel="noopener noreferrer"
          class="book__buy-btn"
          aria-label="Acquista su Amazon"
