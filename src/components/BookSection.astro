---
/*
 * BookSection.astro — Catalogo libri multi-book
 * Griglia di card con link alle pagine dedicate di ciascun libro.
 * Pensato per crescere: aggiungere un elemento a `books` per ogni nuovo titolo.
 */

const books = [
  {
    slug: 'knowledge-graph',
    title: 'AI che Ragiona',
    date: 'Aprile 2026',
    pages: '280+ pagine full color',
    formats: 'Paperback · Hardcover · Kindle',
    description:
      'Dalla teoria dei Knowledge Graph a una pipeline Graph-RAG in produzione: Neo4j, Redis, Ollama, MCP e agenti orchestrati con Microsoft Agent Framework. Tutto eseguibile con un docker compose up.',
    tags: ['Python', 'Neo4j', 'Redis', 'Graph-RAG', 'MCP', 'Agent Framework'],
    cover: '/covers/ai-che-ragiona-it-thumb.jpg',
    amazonUrl: 'https://www.amazon.it/gp/product/B0GWRX64Z8/ref=ox_sc_act_title_1?smid=A1FPE5JXJST57&psc=1',
  },
  // Aggiungi qui i prossimi libri:
  // {
  //   slug: 'next-book-slug',
  //   title: 'Titolo del prossimo libro',
  //   ...,
  //   cover: '/covers/next-book-thumb.jpg',
  // },
];
---

<section class="catalog" id="books" aria-labelledby="catalog-heading">
  <div class="container">
    <div class="catalog__header animate-in">
      <h2 id="catalog-heading" class="catalog__title">Pubblicazioni</h2>
      <p class="catalog__subtitle">
        Libri tecnici per sviluppatori, architect e decision maker
      </p>
    </div>

    <div class="catalog__grid">
      {books.map((book) => (
        <article class="book-card animate-in">
          <a href={`/books/${book.slug}`} class="book-card__link">
            {/* Cover con immagine reale */}
            <div class="book-card__cover">
              <img
                src={book.cover}
                alt={`Copertina: ${book.title}`}
                class="book-card__cover-img"
                width="400"
                height="640"
                loading="lazy"
              />
            </div>

            <div class="book-card__body">
              <div class="book-card__meta">
                <span class="book-card__date">{book.date}</span>
              </div>

              <h3 class="book-card__title">{book.title}</h3>
              <p class="book-card__desc">{book.description}</p>

              <div class="book-card__details">
                <span class="book-card__pages">{book.pages}</span>
                <span class="book-card__formats">{book.formats}</span>
              </div>

              <div class="book-card__tags">
                {book.tags.map((tag) => (
                  <span class="book-card__tag">{tag}</span>
                ))}
              </div>

              {/* Amazon badge */}
              <div class="book-card__badge">
                <img
                  src="/badges/available_at_amazon_en_horizontal_drk.png"
                  alt="Available at Amazon"
                  width="140"
                  height="36"
                  loading="lazy"
                />
              </div>
            </div>
          </a>
        </article>
      ))}
    </div>

    <p class="catalog__trademark">
      Amazon's trademark is used under license from Amazon.com, Inc. or its affiliates.
    </p>
  </div>
</section>

<style>
  .catalog {
    padding: var(--space-3xl) 0;
    border-top: 1px solid var(--color-border);
  }

  .catalog__header {
    text-align: center;
    margin-bottom: var(--space-2xl);
  }

  .catalog__title {
    font-family: var(--font-heading);
    font-size: 0.85rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    color: var(--color-accent);
    margin-bottom: var(--space-sm);
  }

  .catalog__subtitle {
    font-size: 0.95rem;
    color: var(--color-text-muted);
  }

  .catalog__grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(320px, 1fr));
    gap: var(--space-xl);
    max-width: 900px;
    margin: 0 auto;
  }

  /* ── Book Card ── */
  .book-card {
    background: var(--color-bg-card);
    border: 1px solid var(--color-border);
    border-radius: var(--border-radius-lg);
    overflow: hidden;
    transition:
      border-color var(--transition-base),
      box-shadow var(--transition-base),
      transform var(--transition-base);
  }

  .book-card:hover {
    border-color: rgba(33, 150, 243, 0.35);
    box-shadow: 0 0 24px var(--color-accent-glow);
    transform: translateY(-3px);
  }

  .book-card__link {
    display: flex;
    flex-direction: column;
    text-decoration: none;
    color: inherit;
    height: 100%;
  }

  /* ── Cover con immagine reale ── */
  .book-card__cover {
    position: relative;
    overflow: hidden;
    background: #0a0e1a;
    display: flex;
    align-items: center;
    justify-content: center;
    max-height: 280px;
  }

  .book-card__cover-img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: top center;
    transition: transform 0.3s ease;
  }

  .book-card:hover .book-card__cover-img {
    transform: scale(1.03);
  }

  /* ── Card body ── */
  .book-card__body {
    padding: var(--space-lg);
    display: flex;
    flex-direction: column;
    gap: var(--space-sm);
    flex: 1;
  }

  .book-card__meta {
    display: flex;
    align-items: center;
    gap: var(--space-xs);
    font-family: var(--font-heading);
    font-size: 0.7rem;
    color: var(--color-accent);
    text-transform: uppercase;
    letter-spacing: 0.05em;
  }

  .book-card__title {
    font-family: var(--font-heading);
    font-size: 1rem;
    font-weight: 700;
    color: var(--color-text);
    line-height: 1.3;
  }

  .book-card__desc {
    font-size: 0.85rem;
    color: var(--color-text-muted);
    line-height: 1.6;
  }

  .book-card__details {
    display: flex;
    gap: var(--space-md);
    font-family: var(--font-heading);
    font-size: 0.75rem;
    color: var(--color-text-muted);
  }

  .book-card__tags {
    display: flex;
    flex-wrap: wrap;
    gap: 0.3rem;
  }

  .book-card__tag {
    padding: 0.15em 0.6em;
    font-family: var(--font-heading);
    font-size: 0.7rem;
    color: var(--color-text-muted);
    border: 1px solid var(--color-border);
    border-radius: 999px;
  }

  .book-card__badge {
    margin-top: auto;
    padding-top: var(--space-sm);
  }

  .book-card__badge img {
    height: 32px;
    width: auto;
  }

  .catalog__trademark {
    text-align: center;
    font-size: 0.6rem;
    color: var(--color-text-muted);
    opacity: 0.4;
    margin-top: var(--space-xl);
  }

  @media (max-width: 400px) {
    .catalog__grid {
      grid-template-columns: 1fr;
    }
  }
</style>
