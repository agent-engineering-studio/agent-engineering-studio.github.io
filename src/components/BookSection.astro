              <path d="M349.14 23.31V7.21c0-2.45 1.85-4.08 4.08-4.08h72.15c2.32 0 4.17 1.67 4.17 4.08v13.78c-.04 2.32-1.97 5.36-5.44 10.2l-37.39 53.36c13.9-.34 28.57 1.72 41.14 8.84 2.84 1.59 3.62 3.96 3.83 6.28v17.17c0 2.36-2.6 5.11-5.32 3.69-22.23-11.65-51.76-12.92-76.33.13-2.5 1.35-5.15-1.37-5.15-3.73v-16.31c0-2.63.04-7.13 2.63-11.13l43.3-62.12h-37.69c-2.32 0-4.17-1.63-4.17-4.04zM124.82 108.66h-21.95c-2.1-.15-3.77-1.76-3.91-3.77V7.42c0-2.28 1.89-4.08 4.26-4.08h20.46c2.14.09 3.85 1.76 3.99 3.83v13.44h.41c5.36-13.27 15.38-19.45 28.89-19.45 13.69 0 22.24 6.18 28.39 19.45 5.32-13.27 17.42-19.45 30.39-19.45 9.22 0 19.3 3.79 25.48 12.31 7.01 9.46 5.57 23.23 5.57 35.29l-.04 58.04c0 2.28-1.89 4.13-4.21 4.13h-21.91c-2.18-.15-3.91-1.93-3.91-4.13V55.59c0-4.74.41-16.56-.62-21.04-1.63-7.55-6.52-9.68-12.84-9.68-5.28 0-10.82 3.54-13.07 9.22-2.24 5.69-2.02 15.17-2.02 21.5v49.3c0 2.28-1.89 4.13-4.21 4.13h-21.91c-2.19-.15-3.91-1.93-3.91-4.13l-.04-49.3c0-12.52 2.06-30.93-13.44-30.93-15.72 0-15.09 17.95-15.09 30.93v49.3c0 2.28-1.89 4.13-4.21 4.13zM458.44 1.16c33.13 0 51.04 28.43 51.04 64.56 0 34.92-19.79 62.61-51.04 62.61-32.47 0-50.14-28.43-50.14-63.81 0-35.54 17.87-63.36 50.14-63.36zm.19 23.39c-16.42 0-17.42 22.37-17.42 36.31s-.21 43.82 17.23 43.82c17.21 0 18.04-24.08 18.04-38.77 0-9.68-.41-21.25-3.34-30.47-2.49-8.01-7.45-10.89-14.51-10.89zM552.38 108.66h-21.87c-2.19-.15-3.91-1.93-3.91-4.13l-.04-97.16c.19-2.1 2.01-3.73 4.26-3.73h20.34c1.93.09 3.51 1.42 3.91 3.22v14.86h.41c6.14-13.65 14.77-20.12 29.93-20.12 9.89 0 19.54 3.58 25.72 13.44 5.74 9.14 5.74 24.52 5.74 35.54v54.38c-.26 2.01-2.06 3.62-4.26 3.62h-22.03c-2.01-.15-3.66-1.67-3.85-3.62V54c0-12.31 1.42-30.31-13.65-30.31-5.32 0-10.2 3.54-12.64 8.97-3.08 6.87-3.49 13.69-3.49 21.33v50.54c-.04 2.28-1.93 4.13-4.26 4.13zM30.68 60.72c0 8.53 .22 15.63-4.08 23.23-3.49 6.14-9.05 9.93-15.17 9.93-8.42 0-13.36-6.41-13.36-15.89 0-18.7 16.76-22.09 32.61-22.09v4.82zm22.11 53.47c-1.46 1.3-3.56 1.38-5.19.52-7.3-6.06-8.6-8.88-12.59-14.65-12.03 12.