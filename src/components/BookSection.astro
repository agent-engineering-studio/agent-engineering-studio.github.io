          </svg>
          <span class="book__buy-text">
            <span class="book__buy-label">Acquista su Amazon</span>
            <span class="book__buy-formats">Paperback &amp; Kindle</span>
          </span>
        </a>
      </div>

      <!-- Available at Amazon badge (KDP compliant) -->
      <div class="book__amazon-badge animate-in">
        <a
          href={AMAZON_BOOK_URL}
          target="_blank"
          rel="noopener noreferrer"
          aria-label="Disponibile su Amazon"
          class="amazon-badge-link"
        >
          <div class="amazon-badge">
            <span class="amazon-badge__text">disponibile su</span>
            <svg class="amazon-badge__logo" viewBox="0 0 603 182" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
