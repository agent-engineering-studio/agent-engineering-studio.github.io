---
/*
 * SupportSection.astro — "Collabora con noi" teaser in homepage
 * Sezione "Collabora con noi" in homepage
 */
---

<section class="support-section animate-in animate-delay-5" aria-label="Collabora con noi">
  <div class="container">
    <div class="support-section__card">

      <div class="support-section__icon" aria-hidden="true">
        <svg width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
          <path d="M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2"/>
          <circle cx="9" cy="7" r="4"/>
          <path d="M23 21v-2a4 4 0 0 0-3-3.87"/>
          <path d="M16 3.13a4 4 0 0 1 0 7.75"/>
        </svg>
      </div>

      <h2 class="support-section__title">Collabora con noi</h2>

      <p class="support-section__desc">
        Questo è un progetto <strong>aperto</strong>: il codice è su GitHub, i dati sono pubblici
        e la community è benvenuta. Se ti interessa il mondo degli open data italiani,
        del protocollo MCP o degli agenti AI, c'è spazio per contribuire.
      </p>

      <div class="support-section__ways">
        <div class="support-section__way">
          <span class="support-section__way-icon" aria-hidden="true">🛠️</span>
          <div>
            <strong>Contribuisci al codice</strong>
            <span>Apri una PR o una issue sui nostri repo MCP open source</span>
          </div>
        </div>
        <div class="support-section__way">
          <span class="support-section__way-icon" aria-hidden="true">🌍</span>
          <div>
            <strong>Migliora i dati aperti</strong>
            <span>Contribuisci agli open data italiani: dataset PA, OSM, ISTAT</span>
          </div>
        </div>
        <div class="support-section__way">
          <span class="support-section__way-icon" aria-hidden="true">✍️</span>
          <div>
            <strong>Scrivi o traduci</strong>
            <span>Tutorial, guide MCP, articoli in italiano sulla community wiki</span>
          </div>
        </div>
      </div>

      <div class="support-section__actions">
        <a
          href="https://github.com/agent-engineering-studio"
          target="_blank"
          rel="noopener noreferrer"
          class="support-section__btn support-section__btn--primary"
        >
          <svg width="16" height="16" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
            <path d="M12 0C5.374 0 0 5.373 0 12c0 5.302 3.438 9.8 8.207 11.387.599.111.793-.261.793-.577v-2.234c-3.338.726-4.033-1.416-4.033-1.416-.546-1.387-1.333-1.756-1.333-1.756-1.089-.745.083-.729.083-.729 1.205.084 1.839 1.237 1.839 1.237 1.07 1.834 2.807 1.304 3.492.997.107-.775.418-1.305.762-1.604-2.665-.305-5.467-1.334-5.467-5.931 0-1.311.469-2.381 1.236-3.221-.124-.303-.535-1.524.117-3.176 0 0 1.008-.322 3.301 1.23A11.509 11.509 0 0 1 12 5.803c1.02.005 2.047.138 3.006.404 2.291-1.552 3.297-1.23 3.297-1.23.653 1.653.242 2.874.118 3.176.77.84 1.235 1.911 1.235 3.221 0 4.609-2.807 5.624-5.479 5.921.43.372.823 1.102.823 2.222v3.293c0 .319.192.694.801.576C20.566 21.797 24 17.3 24 12c0-6.627-5.373-12-12-12z"/>
          </svg>
          <span>GitHub org</span>
        </a>

        <a
          href="mailto:giuseppe.zileni@hevolus.it?subject=Collaborazione%20Agent%20Engineering%20Studio"
          class="support-section__btn support-section__btn--secondary"
        >
          <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
            <path d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z"/>
            <polyline points="22,6 12,13 2,6"/>
          </svg>
          <span>Scrivici</span>
        </a>
      </div>

      <p class="support-section__coffee">
        Vuoi supportare l'infrastruttura del progetto?
        <a href="https://www.buymeacoffee.com/f9t3zol" target="_blank" rel="noopener noreferrer">☕ Offri un caffè</a>
        oppure diventa
        <a href="https://github.com/sponsors/gzileni" target="_blank" rel="noopener noreferrer">GitHub Sponsor</a>.
      </p>

    </div>
  </div>
</section>

<style>
  .support-section {
    padding: var(--space-xl) 0;
    text-align: center;
  }

  .support-section__card {
    max-width: 620px;
    margin: 0 auto;
    padding: var(--space-xl) var(--space-2xl);
    background: rgba(15, 34, 64, 0.5);
    border: 1px solid var(--color-border);
    border-radius: var(--border-radius-lg, 12px);
    backdrop-filter: blur(8px);
  }

  .support-section__icon {
    color: var(--color-accent);
    margin-bottom: var(--space-sm);
  }

  .support-section__title {
    font-size: 1.3rem;
    font-weight: 600;
    color: var(--color-text);
    margin-bottom: var(--space-sm);
  }

  .support-section__desc {
    color: var(--color-text-muted);
    font-size: 0.92rem;
    line-height: 1.65;
    margin-bottom: var(--space-lg);
    max-width: 460px;
    margin-left: auto;
    margin-right: auto;
  }

  .support-section__desc a {
    color: var(--color-accent);
    text-decoration: underline;
    text-underline-offset: 3px;
  }

  .support-section__desc a:hover {
    color: var(--color-cta);
  }

  .support-section__ways {
    display: flex;
    flex-direction: column;
    gap: var(--space-sm);
    margin-bottom: var(--space-lg);
    text-align: left;
  }

  .support-section__way {
    display: flex;
    align-items: flex-start;
    gap: var(--space-sm);
    padding: 0.75rem 1rem;
    background: rgba(255, 255, 255, 0.03);
    border: 1px solid rgba(255, 255, 255, 0.07);
    border-radius: 8px;
  }

  .support-section__way-icon {
    font-size: 1.1rem;
    flex-shrink: 0;
    margin-top: 2px;
  }

  .support-section__way div {
    display: flex;
    flex-direction: column;
    gap: 2px;
  }

  .support-section__way strong {
    font-size: 0.88rem;
    font-weight: 600;
    color: var(--color-text);
  }

  .support-section__way span {
    font-size: 0.82rem;
    color: var(--color-text-muted);
    line-height: 1.4;
  }

  .support-section__actions {
    display: flex;
    gap: var(--space-sm);
    justify-content: center;
    flex-wrap: wrap;
    margin-bottom: var(--space-md);
  }

  .support-section__btn {
    display: inline-flex;
    align-items: center;
    gap: 0.45rem;
    padding: 0.6rem 1.4rem;
    border-radius: 8px;
    font-size: 0.88rem;
    font-weight: 600;
    text-decoration: none;
    transition: background 0.2s ease, transform 0.2s ease, box-shadow 0.2s ease;
  }

  .support-section__btn--primary {
    background: var(--color-accent, #4A90E2);
    color: #ffffff;
    box-shadow: 0 2px 8px rgba(74, 144, 226, 0.3);
  }

  .support-section__btn--primary:hover {
    background: var(--color-cta, #357ABD);
    transform: translateY(-1px);
    box-shadow: 0 4px 14px rgba(74, 144, 226, 0.4);
    color: #ffffff;
  }

  .support-section__btn--secondary {
    background: rgba(255, 255, 255, 0.06);
    color: var(--color-text);
    border: 1px solid var(--color-border);
  }

  .support-section__btn--secondary:hover {
    background: rgba(255, 255, 255, 0.1);
    transform: translateY(-1px);
    color: var(--color-text);
  }

  .support-section__coffee {
    font-size: 0.8rem;
    color: var(--color-text-muted);
    margin-top: var(--space-sm);
    line-height: 1.5;
  }

  .support-section__coffee a {
    color: var(--color-accent);
    text-decoration: underline;
    text-underline-offset: 2px;
  }

  .support-section__coffee a:hover {
    color: var(--color-cta);
  }

  @media (max-width: 500px) {
    .support-section__card {
      padding: var(--space-lg) var(--space-md);
    }

    .support-section__actions {
      flex-direction: column;
      align-items: center;
    }
  }
</style>

