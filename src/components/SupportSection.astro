---
/*
 * SupportSection.astro — Teaser "Supporta il progetto" in homepage
 * Per la pagina completa con tier, milestone e sezione istituzionale: /support
 */
---

<section class="support-section animate-in animate-delay-5" aria-label="Supporta il progetto">
  <div class="container">
    <div class="support-section__card">
      <div class="support-section__icon" aria-hidden="true">
        <svg width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
          <path d="M18 8h1a4 4 0 0 1 0 8h-1"/>
          <path d="M2 8h16v9a4 4 0 0 1-4 4H6a4 4 0 0 1-4-4V8z"/>
          <line x1="6" y1="1" x2="6" y2="4"/>
          <line x1="10" y1="1" x2="10" y2="4"/>
          <line x1="14" y1="1" x2="14" y2="4"/>
        </svg>
      </div>

      <h2 class="support-section__title">Supporta il laboratorio</h2>

      <p class="support-section__desc">
        Nessun VC. Nessun paywall. Il laboratorio è sostenuto da chi trova utile il suo lavoro.
        I fondi vanno a infrastruttura cloud, nuovi libri, workshop gratuiti e progetti open per la community italiana.
      </p>

      <div class="support-section__actions">
        <a
          href="https://www.buymeacoffee.com/f9t3zol"
          target="_blank"
          rel="noopener noreferrer"
          class="support-section__btn support-section__btn--bmc"
        >
          <span aria-hidden="true">☕</span>
          <span>Offri un caffè</span>
        </a>

        <a
          href="https://github.com/sponsors/gzileni"
          target="_blank"
          rel="noopener noreferrer"
          class="support-section__btn support-section__btn--gh"
        >
          <svg width="16" height="16" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
            <path d="M12 0C5.374 0 0 5.373 0 12c0 5.302 3.438 9.8 8.207 11.387.599.111.793-.261.793-.577v-2.234c-3.338.726-4.033-1.416-4.033-1.416-.546-1.387-1.333-1.756-1.333-1.756-1.089-.745.083-.729.083-.729 1.205.084 1.839 1.237 1.839 1.237 1.07 1.834 2.807 1.304 3.492.997.107-.775.418-1.305.762-1.604-2.665-.305-5.467-1.334-5.467-5.931 0-1.311.469-2.381 1.236-3.221-.124-.303-.535-1.524.117-3.176 0 0 1.008-.322 3.301 1.23A11.509 11.509 0 0 1 12 5.803c1.02.005 2.047.138 3.006.404 2.291-1.552 3.297-1.23 3.297-1.23.653 1.653.242 2.874.118 3.176.77.84 1.235 1.911 1.235 3.221 0 4.609-2.807 5.624-5.479 5.921.43.372.823 1.102.823 2.222v3.293c0 .319.192.694.801.576C20.566 21.797 24 17.3 24 12c0-6.627-5.373-12-12-12z"/>
          </svg>
          <span>GitHub Sponsors</span>
        </a>
      </div>

      <a href="/support" class="support-section__more">
        Scopri tutti i livelli di supporto e le milestone
        <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
          <polyline points="9 18 15 12 9 6"/>
        </svg>
      </a>
    </div>
  </div>
</section>

<style>
  .support-section {
    padding: var(--space-xl) 0;
    text-align: center;
  }

  .support-section__card {
    max-width: 580px;
    margin: 0 auto;
    padding: var(--space-xl) var(--space-2xl);
    background: rgba(15, 34, 64, 0.5);
    border: 1px solid var(--color-border);
    border-radius: var(--border-radius-lg, 12px);
    backdrop-filter: blur(8px);
  }

  .support-section__icon {
    color: #FF813F;
    margin-bottom: var(--space-sm);
  }

  .support-section__title {
    font-size: 1.3rem;
    font-weight: 600;
    color: var(--color-text);
    margin-bottom: var(--space-sm);
  }

  .support-section__desc {
    color: var(--color-text-muted);
    font-size: 0.92rem;
    line-height: 1.65;
    margin-bottom: var(--space-lg);
    max-width: 420px;
    margin-left: auto;
    margin-right: auto;
  }

  .support-section__actions {
    display: flex;
    gap: var(--space-sm);
    justify-content: center;
    flex-wrap: wrap;
    margin-bottom: var(--space-lg);
  }

  .support-section__btn {
    display: inline-flex;
    align-items: center;
    gap: 0.45rem;
    padding: 0.6rem 1.4rem;
    border-radius: 8px;
    font-size: 0.88rem;
    font-weight: 600;
    text-decoration: none;
    transition: background 0.2s ease, transform 0.2s ease, box-shadow 0.2s ease;
  }

  .support-section__btn--bmc {
    background: #FF813F;
    color: #ffffff;
    box-shadow: 0 2px 8px rgba(255, 129, 63, 0.3);
  }

  .support-section__btn--bmc:hover {
    background: #e5712e;
    transform: translateY(-1px);
    box-shadow: 0 4px 14px rgba(255, 129, 63, 0.4);
    color: #ffffff;
  }

  .support-section__btn--gh {
    background: rgba(255, 255, 255, 0.06);
    color: var(--color-text);
    border: 1px solid var(--color-border);
  }

  .support-section__btn--gh:hover {
    background: rgba(255, 255, 255, 0.1);
    transform: translateY(-1px);
    color: var(--color-text);
  }

  .support-section__more {
    display: inline-flex;
    align-items: center;
    gap: 0.3rem;
    font-size: 0.82rem;
    color: var(--color-accent);
    text-decoration: none;
    border-bottom: 1px solid transparent;
    transition: border-color var(--transition-fast), color var(--transition-fast);
  }

  .support-section__more:hover {
    color: var(--color-cta);
    border-bottom-color: var(--color-cta);
  }

  @media (max-width: 500px) {
    .support-section__card {
      padding: var(--space-lg) var(--space-md);
    }

    .support-section__actions {
      flex-direction: column;
      align-items: center;
    }
  }
</style>
