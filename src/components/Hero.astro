---
/*
 * Hero.astro — Sezione hero principale
 */
---

<header class="hero">
  <div class="container">

    <!-- Tagline -->
    <p class="hero__tagline animate-in animate-delay-1">
      Uno spazio di studio sugli agenti AI.
    </p>

    <!-- Sottotitolo -->
    <p class="hero__subtitle animate-in animate-delay-2">
      Appunti, esperimenti e codice open source per capire come si costruiscono
      agenti AI che ragionano davvero. Un laboratorio personale aperto a chi vuole
      imparare insieme.
    </p>

    <!-- Badge -->
    <div class="hero__badges animate-in animate-delay-3">
      <span class="hero__badge hero__badge--neutral">Open Source</span>
      <span class="hero__badge hero__badge--neutral">MIT License</span>
      <span class="hero__badge hero__badge--neutral">Studio personale</span>
    </div>

    <!-- CTA -->
    <div class="hero__cta animate-in animate-delay-4">

      <a href="#books" class="hero__btn hero__btn--primary">
        <!-- Book icon -->
        <svg width="17" height="17" viewBox="0 0 24 24" fill="none" stroke="currentColor"
             stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
          <path d="M4 19.5A2.5 2.5 0 0 1 6.5 17H20"/>
          <path d="M6.5 2H20v20H6.5A2.5 2.5 0 0 1 4 19.5v-15A2.5 2.5 0 0 1 6.5 2z"/>
        </svg>
        Scopri il libro
      </a>

      <a href="/blog" class="hero__btn hero__btn--secondary">
        <!-- Pencil icon -->
        <svg width="17" height="17" viewBox="0 0 24 24" fill="none" stroke="currentColor"
             stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
          <path d="M12 20h9"/>
          <path d="M16.5 3.5a2.121 2.121 0 0 1 3 3L7 19l-4 1 1-4L16.5 3.5z"/>
        </svg>
        Vai al blog
      </a>

    </div>
  </div>
</header>

<style>
  .hero {
    padding: var(--space-2xl) 0 var(--space-xl);
    text-align: center;
  }

  .hero__tagline {
    font-size: clamp(1.25rem, 3vw, 1.7rem);
    font-weight: 700;
    color: var(--color-text);
    margin-bottom: var(--space-sm);
    letter-spacing: -0.01em;
  }

  .hero__subtitle {
    font-size: clamp(0.9rem, 2vw, 1.05rem);
    color: var(--color-text-muted);
    max-width: 560px;
    margin: 0 auto var(--space-lg);
    line-height: 1.65;
  }

  .hero__badges {
    display: flex;
    gap: 0.5rem;
    justify-content: center;
    flex-wrap: wrap;
    margin-bottom: var(--space-xl);
  }

  .hero__badge {
    display: inline-block;
    padding: 0.3rem 0.8rem;
    border-radius: 999px;
    font-size: 0.78rem;
    font-weight: 600;
    background: var(--color-accent);
    color: #fff;
    text-decoration: none;
    transition: background 0.2s;
  }

  .hero__badge--neutral {
    background: rgba(255, 255, 255, 0.08);
    color: var(--color-text-muted);
    border: 1px solid var(--color-border);
  }

  .hero__cta {
    display: flex;
    gap: var(--space-sm);
    justify-content: center;
    flex-wrap: wrap;
  }

  .hero__btn {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    padding: 0.7rem 1.5rem;
    border-radius: 8px;
    font-size: 0.95rem;
    font-weight: 600;
    text-decoration: none;
    transition: background 0.2s, transform 0.18s, box-shadow 0.2s;
  }

  .hero__btn--primary {
    background: var(--color-accent, #4A90E2);
    color: #ffffff;
    box-shadow: 0 2px 10px rgba(74, 144, 226, 0.3);
  }

  .hero__btn--primary:hover {
    background: var(--color-cta, #357ABD);
    transform: translateY(-2px);
    box-shadow: 0 6px 18px rgba(74, 144, 226, 0.4);
    color: #ffffff;
  }

  .hero__btn--secondary {
    background: rgba(255, 255, 255, 0.07);
    color: var(--color-text);
    border: 1px solid var(--color-border);
  }

  .hero__btn--secondary:hover {
    background: rgba(255, 255, 255, 0.13);
    transform: translateY(-2px);
    color: var(--color-text);
  }

  @media (max-width: 480px) {
    .hero__cta {
      flex-direction: column;
      align-items: center;
    }
  }
</style>
