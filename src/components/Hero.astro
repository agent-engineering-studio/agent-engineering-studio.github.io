---
/*
 * Hero.astro — Sezione hero principale
 */
---

<header class="hero">
  <div class="container">

    <!-- Tagline -->
    <p class="hero__tagline animate-in animate-delay-1">
      MCP server open-source per i dati pubblici italiani.
    </p>

    <!-- Sottotitolo -->
    <p class="hero__subtitle animate-in animate-delay-2">
      Costruiamo strumenti aperti per interrogare OpenStreetMap, ISTAT, CKAN
      e i dataset della PA in linguaggio naturale.
    </p>

    <!-- Badge -->
    <div class="hero__badges animate-in animate-delay-3">
      <a href="https://github.com/agent-engineering-studio" target="_blank" rel="noopener noreferrer" class="hero__badge">Open Source</a>
      <span class="hero__badge hero__badge--neutral">MIT License</span>
      <span class="hero__badge hero__badge--neutral">&#127470;&#127481; Dati italiani</span>
    </div>

    <!-- CTA -->
    <div class="hero__cta animate-in animate-delay-4">

      <a
        href="https://github.com/agent-engineering-studio"
        target="_blank"
        rel="noopener noreferrer"
        class="hero__btn hero__btn--primary"
      >
        <!-- GitHub icon -->
        <svg width="17" height="17" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
          <path d="M12 0C5.374 0 0 5.373 0 12c0 5.302 3.438 9.8 8.207 11.387.599.111.793-.261.793-.577v-2.234c-3.338.726-4.033-1.416-4.033-1.416-.546-1.387-1.333-1.756-1.333-1.756-1.089-.745.083-.729.083-.729 1.205.084 1.839 1.237 1.839 1.237 1.07 1.834 2.807 1.304 3.492.997.107-.775.418-1.305.762-1.604-2.665-.305-5.467-1.334-5.467-5.931 0-1.311.469-2.381 1.236-3.221-.124-.303-.535-1.524.117-3.176 0 0 1.008-.322 3.301 1.23A11.509 11.509 0 0 1 12 5.803c1.02.005 2.047.138 3.006.404 2.291-1.552 3.297-1.23 3.297-1.23.653 1.653.242 2.874.118 3.176.77.84 1.235 1.911 1.235 3.221 0 4.609-2.807 5.624-5.479 5.921.43.372.823 1.102.823 2.222v3.293c0 .319.192.694.801.576C20.566 21.797 24 17.3 24 12c0-6.627-5.373-12-12-12z"/>
        </svg>
        Esplora i repo
      </a>

      <a href="/blog" class="hero__btn hero__btn--secondary">
        <!-- Book icon -->
        <svg width="17" height="17" viewBox="0 0 24 24" fill="none" stroke="currentColor"
             stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
          <path d="M4 19.5A2.5 2.5 0 0 1 6.5 17H20"/>
          <path d="M6.5 2H20v20H6.5A2.5 2.5 0 0 1 4 19.5v-15A2.5 2.5 0 0 1 6.5 2z"/>
        </svg>
        Leggi il blog
      </a>

    </div>
  </div>
</header>

<style>
  .hero {
    padding: var(--space-2xl) 0 var(--space-xl);
    text-align: center;
  }

  .hero__tagline {
    font-size: clamp(1.25rem, 3vw, 1.7rem);
    font-weight: 700;
    color: var(--color-text);
    margin-bottom: var(--space-sm);
    letter-spacing: -0.01em;
  }

  .hero__subtitle {
    font-size: clamp(0.9rem, 2vw, 1.05rem);
    color: var(--color-text-muted);
    max-width: 520px;
    margin: 0 auto var(--space-lg);
    line-height: 1.65;
  }

  .hero__badges {
    display: flex;
    gap: 0.5rem;
    justify-content: center;
    flex-wrap: wrap;
    margin-bottom: var(--space-xl);
  }

  .hero__badge {
    display: inline-block;
    padding: 0.3rem 0.8rem;
    border-radius: 999px;
    font-size: 0.78rem;
    font-weight: 600;
    background: var(--color-accent);
    color: #fff;
    text-decoration: none;
    transition: background 0.2s;
  }

  .hero__badge:hover {
    background: var(--color-cta);
  }

  .hero__badge--neutral {
    background: rgba(255, 255, 255, 0.08);
    color: var(--color-text-muted);
    border: 1px solid var(--color-border);
  }

  .hero__cta {
    display: flex;
    gap: var(--space-sm);
    justify-content: center;
    flex-wrap: wrap;
  }

  .hero__btn {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    padding: 0.7rem 1.5rem;
    border-radius: 8px;
    font-size: 0.95rem;
    font-weight: 600;
    text-decoration: none;
    transition: background 0.2s, transform 0.18s, box-shadow 0.2s;
  }

  .hero__btn--primary {
    background: var(--color-accent, #4A90E2);
    color: #ffffff;
    box-shadow: 0 2px 10px rgba(74, 144, 226, 0.3);
  }

  .hero__btn--primary:hover {
    background: var(--color-cta, #357ABD);
    transform: translateY(-2px);
    box-shadow: 0 6px 18px rgba(74, 144, 226, 0.4);
    color: #ffffff;
  }

  .hero__btn--secondary {
    background: rgba(255, 255, 255, 0.07);
    color: var(--color-text);
    border: 1px solid var(--color-border);
  }

  .hero__btn--secondary:hover {
    background: rgba(255, 255, 255, 0.13);
    transform: translateY(-2px);
    color: var(--color-text);
  }

  @media (max-width: 480px) {
    .hero__cta {
      flex-direction: column;
      align-items: center;
    }
  }
</style>
