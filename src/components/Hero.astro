---
/*
 * Hero.astro — Sezione hero principale
 * Contiene logo, tagline e sottotitolo.
 * Per modificare i testi: aggiorna direttamente l'HTML qui sotto.
 */
---

<header class="hero">
  <div class="container">
    <!-- Logo principale -->
    <div class="hero__logo animate-in">
      <img
        src="/logo-horizontal.png"
        alt="Agent Engineering Studio"
        class="hero__logo-img"
        width="480"
        height="120"
      />
    </div>

    <p class="hero__tagline animate-in animate-delay-1">
      Il laboratorio dove le idee diventano AI agents.
    </p>

    <p class="hero__subtitle animate-in animate-delay-2">
      Starter kit, template, demo end-to-end e best practice &mdash; dal concept alla prima release.
    </p>
  </div>
</header>

<style>
  .hero {
    padding: var(--space-4xl) 0 var(--space-3xl);
    text-align: center;
  }

  .hero__logo {
    margin-bottom: var(--space-xl);
    display: flex;
    justify-content: center;
  }

  .hero__logo-img {
    width: 100%;
    max-width: 520px;
    height: auto;
    filter: drop-shadow(0 0 30px rgba(33, 150, 243, 0.25));
    animation: logo-glow 4s ease-in-out infinite;
  }

  @keyframes logo-glow {
    0%, 100% {
      filter: drop-shadow(0 0 20px rgba(33, 150, 243, 0.15));
    }
    50% {
      filter: drop-shadow(0 0 45px rgba(33, 150, 243, 0.35));
    }
  }

  .hero__tagline {
    font-family: var(--font-body);
    font-size: clamp(1.1rem, 2.5vw, 1.4rem);
    font-weight: 500;
    color: var(--color-text);
    margin-bottom: var(--space-sm);
  }

  .hero__subtitle {
    font-size: clamp(0.95rem, 2vw, 1.1rem);
    color: var(--color-text-muted);
    max-width: 600px;
    margin: 0 auto;
  }
</style>
